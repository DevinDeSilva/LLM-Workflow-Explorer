                    rdfs:subClassOf resource:SIO_001429 ;
                    dc:identifier "SIO_001431" ;
                    terms:alternative "rank 0 tensor"@en ;
                    terms:description "a scalar is a rank 0 tensor and is an element of a field that is used to define a vector space."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "scalar"@en .



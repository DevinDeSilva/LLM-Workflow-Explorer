###  http://semanticscience.org/resource/SIO_000920
resource:SIO_000920 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000367 ;
                    dc:identifier "SIO_000920" ;
                    terms:description "An independent variable is a variable that may take on different values independent of other elements in a system."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "independent variable"@en .


###  http://semanticscience.org/resource/SIO_000921

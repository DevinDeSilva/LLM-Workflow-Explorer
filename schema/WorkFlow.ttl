###  http://semanticscience.org/resource/SIO_001224
resource:SIO_001224 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010072 ;
                    dc:identifier "SIO_001224" ;
                    terms:description "An amino acid is an organic molecule composed of a carbon bonded to four different groups: a carboxyl group, an amino group, an R group, and a hydrogen atom. In the case of glycine, the R group is another hydrogen atom."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "amino acid"@en .


###  http://semanticscience.org/resource/SIO_001225
resource:SIO_001225 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010335 ;
                    dc:identifier "SIO_001225" ;
                    terms:description "A cisregulatory element is a DNA sequence located on the same DNA strand or chromosome as the gene whose expression it affects. "@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "cis regulatory element"@en .


###  http://semanticscience.org/resource/SIO_001226

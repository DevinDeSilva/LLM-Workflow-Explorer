                    rdfs:subClassOf resource:SIO_010335 ;
                    dc:identifier "SIO_001226" ;
                    terms:description "A trans-regulatory element is a DNA sequence associated with the regulation of a gene located outside the genomic region supporting the corresponding structural DNA region of the trans-regulatory element (i.e., a different DNA strand or different chromosome)."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "trans-regulatory element"@en .



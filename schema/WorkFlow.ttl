                    rdfs:subClassOf resource:SIO_001008 ;
                    owl:disjointWith resource:SIO_001010 ;
                    dc:identifier "SIO_001009" ;
                    terms:description "toxic is the quality of a substance imparing the normal functioning of a  system."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "toxic"@en .


###  http://semanticscience.org/resource/SIO_001010
resource:SIO_001010 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001008 ;
                    dc:identifier "SIO_001010" ;
                    terms:description "non toxic is the quality of a substance having no damaging effect to a system."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "non toxic"@en .


###  http://semanticscience.org/resource/SIO_001011
resource:SIO_001011 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000026 ;
                    dc:identifier "SIO_001011" ;
                    terms:description "chemical quality is the quality of a chemical entity."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "chemical quality"@en .


###  http://semanticscience.org/resource/SIO_001012
resource:SIO_001012 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010058 ;
                    dc:identifier "SIO_001012" ;
                    terms:description "healthy is an organismal state of complete physical, mental and social well-being."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "healthy"@en .


###  http://semanticscience.org/resource/SIO_001013
resource:SIO_001013 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000258 ;
                    dc:identifier "SIO_001013" ;
                    terms:description "age is the length of time that a person has lived or a thing has existed."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "age"@en .


###  http://semanticscience.org/resource/SIO_001014
resource:SIO_001014 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000475 ;
                    dc:identifier "SIO_001014" ;
                    terms:description "ethnicity is the biological quality of membership in a social group based on a common heritage."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "ethnicity"@en .


###  http://semanticscience.org/resource/SIO_001015
resource:SIO_001015 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000475 ;
                    dc:identifier "SIO_001015" ;
                    terms:description "race is a characteristic of an individual by heritable phenotypic characteristics, geographic ancestry, physical appearance, ethnicity, and social status."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "race"@en .


###  http://semanticscience.org/resource/SIO_001016
resource:SIO_001016 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001062 ;
                    dc:identifier "SIO_001016" ;
                    terms:description "An ethnic group is a group of people whose members identify with each other through a common heritage, consisting of a common culture, including a shared language or dialect. "@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "ethnic group"@en .


###  http://semanticscience.org/resource/SIO_001017
resource:SIO_001017 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000136 ;
                    dc:identifier "SIO_001017" ;
                    terms:description "A syndrome is composed of a set of several clinically recognizable features, signs (observed by someone other than the patient), symptoms (reported by the patient), phenomena or characteristics that often occur together."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "syndrome"@en .


###  http://semanticscience.org/resource/SIO_001018
resource:SIO_001018 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000257 ;
                    dc:identifier "SIO_001018" ;
                    terms:description "A ratio is a relationship between two numbers of the same kind expressed arithmetically as a dimensionless quotient of the two which explicitly indicates how many times the first number contains the second."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "ratio"@en .


###  http://semanticscience.org/resource/SIO_001019
resource:SIO_001019 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000258 ;
                    dc:identifier "SIO_001019" ;
                    terms:description "A dose is the quantity of a chemical substance administered to a biological system."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "dose"@en .


###  http://semanticscience.org/resource/SIO_001020
resource:SIO_001020 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001019 ;
                    dc:identifier "SIO_001020" ;
                    terms:description "effective dose is the amount of a substance required to produce an effect on a predefined percentage of a population."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "effective dose"@en .


###  http://semanticscience.org/resource/SIO_001021
resource:SIO_001021 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000638 ;
                    dc:identifier "SIO_001021" ;
                    terms:description "An expected value (or e-value) is the weighted average of all possible values that a random variable can take on."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "expected value"@en .


###  http://semanticscience.org/resource/SIO_001022
resource:SIO_001022 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001024 ;
                    dc:identifier "SIO_001022" ;
                    terms:alternative "clinical laboratory test"@en ;
                    terms:description "A diagnostic test is a procedure performed to confirm, or determine the presence of disease in an individual suspected of having the disease, usually following the report of symptoms, or based on the results of other medical tests."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "diagnostic test"@en .


###  http://semanticscience.org/resource/SIO_001023
resource:SIO_001023 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001024 ;
                    dc:identifier "SIO_001023" ;
                    terms:description "A medical screening is a medical test or series used to detect or predict the presence of disease in individuals at risk for disease within a defined group, such as a population, family, or workforce"@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "medical screening"@en .


###  http://semanticscience.org/resource/SIO_001024
resource:SIO_001024 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000999 ;
                    dc:identifier "SIO_001024" ;
                    terms:description "A medical procedure is a procedure to identify, examine, alleviate or eliminate an undesirable biological disease or disorder."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "medical procedure"@en .


###  http://semanticscience.org/resource/SIO_001025
resource:SIO_001025 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000256 ;
                    dc:identifier "SIO_001025" ;
                    terms:description "A prognosis is a proposition about the likely course of a disease, the chance of recovery or recurrence."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "prognosis"@en .


###  http://semanticscience.org/resource/SIO_001026
resource:SIO_001026 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000148 ;
                    dc:identifier "SIO_001026" ;
                    terms:description "A report is a textual document made that present focused, salient content to a specific audience."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "report"@en .


###  http://semanticscience.org/resource/SIO_001027
resource:SIO_001027 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000088 ;
                    dc:identifier "SIO_001027" ;
                    terms:description "A medical health record is a record of a single patient's medical history."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "medical health record"@en .


###  http://semanticscience.org/resource/SIO_001028
resource:SIO_001028 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001026 ;
                    dc:identifier "SIO_001028" ;
                    terms:description "A medical report is a report prepared by a health care practioner about test outcomes or health status of an individual."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "medical report"@en .


###  http://semanticscience.org/resource/SIO_001029
resource:SIO_001029 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000154 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000217 ;
                                      owl:someValuesFrom resource:SIO_001035
                                    ] ;
                    dc:identifier "SIO_001029" ;
                    terms:description "A peer reviewed article is an article that has undergone peer-review and deemed acceptable for publication."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "peer reviewed article"@en .


###  http://semanticscience.org/resource/SIO_001030
resource:SIO_001030 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000654 ;
                    dc:identifier "SIO_001030" ;
                    terms:description "A major version number is a version of a software that exhibits a significant change in functionalilty from a prior version."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "major version number"@en .


###  http://semanticscience.org/resource/SIO_001031
resource:SIO_001031 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000654 ;
                    dc:identifier "SIO_001031" ;
                    terms:description "A minor version number is a version of a software that exhibits minor features or significant fix from a prior version."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "minor version number"@en .


###  http://semanticscience.org/resource/SIO_001032
resource:SIO_001032 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000654 ;
                    dc:identifier "SIO_001032" ;
                    terms:description "A revision number is a version of a software in which bugs have been fixed from a prior version."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "revision number"@en .


###  http://semanticscience.org/resource/SIO_001033
resource:SIO_001033 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000026 ,

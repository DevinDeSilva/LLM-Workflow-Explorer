                    rdfs:subClassOf resource:SIO_001119 ;
                    dc:identifier "SIO_001345" ;
                    terms:description "A gene-variant disease association in which a somatic mutation in the gene/protein results in the development or maintenance of the disease, and it may not be passed on to offspring."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "gene-disease association linked with somatic causal mutation"@en .



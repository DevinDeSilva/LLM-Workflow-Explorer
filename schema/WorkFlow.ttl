                    rdfs:subClassOf resource:SIO_001251 ,
                                    resource:SIO_001252 ;
                    dc:identifier "SIO_001248" ;
                    terms:description "an open interval is an interval that does not include its endpoints."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "open interval"@en ;
                    skos:example "(0,1) is an open interval that is greater than 0 and less than 1."@en .



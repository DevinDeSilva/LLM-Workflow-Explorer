                    rdfs:subClassOf resource:SIO_001263 ;
                    dc:identifier "SIO_001264" ;
                    terms:description "homozygous is the quality of a biological organism in which there are two identical alleles at a given locus." ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "homozygous"@en .


###  http://semanticscience.org/resource/SIO_001265

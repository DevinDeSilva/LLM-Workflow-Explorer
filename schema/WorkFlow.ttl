###  http://semanticscience.org/resource/SIO_001351
resource:SIO_001351 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001018 ;
                    dc:identifier "SIO_001351" ;
                    terms:description """DisGeNET Disease specificity is a measure of disease coverage. It is calculated from the negative base 2 log of the ratio of number of diseases associated to the total number of diseases.

The measure is described here: http://www.disgenet.org/web/DisGeNET/menu/dbinfo#specificity"""@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "DisGeNET disease specificity"@en .


###  http://semanticscience.org/resource/SIO_001352
resource:SIO_001352 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001018 ;
                    dc:identifier "SIO_001352" ;
                    terms:description """The DisGeNET pleiotropy index is a measure of specificity as it pertains to classes of disease. The disease pleotropy index is computed from the ratio of the number of disease classes associated with an entity over the total number of disease classes multplied by 100. 

The measure is defined here: http://www.disgenet.org/web/DisGeNET/menu/dbinfo#pleiotropy"""@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "DisGeNET Pleiotropy Index"@en .



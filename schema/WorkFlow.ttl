                    rdfs:subClassOf resource:SIO_001422 ;
                    dc:identifier "SIO_001423" ;
                    terms:description "a strong chemical salt is a chemical salt that is composed of strong electrolytes. Strong chemical salts contain Na,K,NH4 or NO3, CIO4, CH3COO."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "strong chemical salt"@en .



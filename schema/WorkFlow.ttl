                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "abstract section"@en .


###  http://semanticscience.org/resource/SIO_000189
resource:SIO_000189 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000189" ;
                    terms:description "An acknowledgements section is a document section that identifies individuals, groups or organizations for their support in the development of the work."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;

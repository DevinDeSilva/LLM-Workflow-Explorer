                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "imaginary"@en .


###  http://semanticscience.org/resource/SIO_001445
resource:SIO_001445 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010043 ,
                                    resource:SIO_010455 ,

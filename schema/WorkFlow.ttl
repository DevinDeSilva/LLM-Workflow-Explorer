                                      owl:onClass resource:SIO_011125
                                    ] ;
                    dc:identifier "SIO_010674" ;
                    terms:description "A binary compound is a mereological maximum sum of two kinds of weakly connected entities."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "binary compound"@en .


###  http://semanticscience.org/resource/SIO_010775
resource:SIO_010775 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010455 ;
                    dc:identifier "SIO_010775" ;
                    terms:description "A stereoisomer is an isomer in which the atomic connectivity is the same, but differs in its spatial arrangement of atoms."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "stereoisomer"@en .


###  http://semanticscience.org/resource/SIO_010776
resource:SIO_010776 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010775 ;
                    dc:identifier "SIO_010776" ;
                    terms:description "A diastereomer is a stereoisomer that is not a mirror image of its isomer."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "diastereomer"@en .


###  http://semanticscience.org/resource/SIO_010777
resource:SIO_010777 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010775 ;
                    dc:identifier "SIO_010777" ;
                    terms:description "An enantiomer is a stereoisomer that is a mirror image of its isomer."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "enantiomer"@en .


###  http://semanticscience.org/resource/SIO_010778
resource:SIO_010778 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010775 ;
                    dc:identifier "SIO_010778" ;
                    terms:description "An optical isomer is a stereoisomer that rotates the plane of polarization of a beam of plane polarized light."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "optical isomer"@en .


###  http://semanticscience.org/resource/SIO_010779
resource:SIO_010779 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010455 ;
                    dc:identifier "SIO_010779" ;
                    terms:description "A structural isomer is an isomer in which the atoms are joined together in different ways."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "structural isomer"@en .


###  http://semanticscience.org/resource/SIO_010780
resource:SIO_010780 rdf:type owl:Class ;
                    owl:equivalentClass [ rdf:type owl:Class ;
                                          owl:unionOf ( resource:SIO_010782
                                                        resource:SIO_010783
                                                      )
                                        ] ;
                    rdfs:subClassOf resource:SIO_000624 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000369 ;
                                      owl:minQualifiedCardinality "3"^^xsd:nonNegativeInteger ;
                                      owl:onClass resource:SIO_010044
                                    ] ;
                    dc:identifier "SIO_010780" ;
                    terms:description "A ring is a submolecule with a circular topology."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "ring"@en .


###  http://semanticscience.org/resource/SIO_010781
resource:SIO_010781 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010780 ;
                    dc:identifier "SIO_010781" ;
                    terms:description "An aromatic ring is a ring in which the electrons are delocalized across all atoms in the ring."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "aromatic ring"@en .


###  http://semanticscience.org/resource/SIO_010782
resource:SIO_010782 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010780 ;
                    owl:disjointWith resource:SIO_010783 ;
                    dc:identifier "SIO_010782" ;
                    terms:description "A heterocyclic ring is a ring containing a hetero atom."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "heterocyclic ring"@en .


###  http://semanticscience.org/resource/SIO_010783
resource:SIO_010783 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010780 ;
                    dc:identifier "SIO_010783" ;
                    terms:description "A homocyclic ring is a ring where the atoms are of a single type."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "homocyclic ring"@en .


###  http://semanticscience.org/resource/SIO_010784
resource:SIO_010784 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010674 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000273 ;
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass resource:SIO_010457
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000273 ;
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass resource:SIO_010458
                                    ] ;
                    dc:identifier "SIO_010784" ;
                    terms:description "An ionic compound is a mereological maximal sum of weakly connected paired positive and negative ions."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "ionic compound"@en .


###  http://semanticscience.org/resource/SIO_010785
resource:SIO_010785 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010037 ;
                    dc:identifier "SIO_010785" ;
                    terms:description "An allotrope is a structural variant of a chemical element."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "allotrope"@en .


###  http://semanticscience.org/resource/SIO_010786
resource:SIO_010786 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010785 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000273 ;
                                      owl:allValuesFrom resource:SIO_011001
                                    ] ;
                    dc:identifier "SIO_010786" ;
                    terms:description "A carbon allotrope is a chemical substance composed of carbon."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "carbon allotrope"@en .


###  http://semanticscience.org/resource/SIO_010787
resource:SIO_010787 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010786 ;
                    dc:identifier "SIO_010787" ;
                    terms:description "diamond is a carbon allotrope in which each carbon atom in diamond is covalently bonded to four other carbons in a tetrahedron. These tetrahedrons together form a 3-dimensional network of puckered six-membered rings of atoms."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "diamond"@en .


###  http://semanticscience.org/resource/SIO_010788
resource:SIO_010788 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010786 ;
                    dc:identifier "SIO_010788" ;
                    terms:description "graphite is an allotrope of carbon which is a conductor, and is the most stable form of solid carbon."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "graphite"@en .


###  http://semanticscience.org/resource/SIO_010789
resource:SIO_010789 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010786 ;
                    dc:identifier "SIO_010789" ;
                    terms:description "fullerene is a carbon allotrope which take the form of a hollow sphere, ellipsoid, or tube."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "fullerene"@en .


###  http://semanticscience.org/resource/SIO_010790
resource:SIO_010790 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010786 ;
                    dc:identifier "SIO_010790" ;
                    terms:description "aggregate of carbon nanorods is an allotrope of carbon considered to be the least compressible material known, as measured by its isothermal bulk modulus; aggregated diamond nanorods have a modulus of 491 gigapascals (GPa), while a conventional diamond has a modulus of 442 GPa. ADNRs are also 0.3% denser than regular diamond."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "aggregated carbon nanorods"@en .


###  http://semanticscience.org/resource/SIO_010791
resource:SIO_010791 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010786 ;
                    dc:identifier "SIO_010791" ;
                    terms:description "amorphous carbon is an allotrope of carbon that does not have any crystalline structure. As with all glassy materials, some short-range order can be observed, but there is no long-range pattern of atomic positions."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "amorphous carbon"@en .


###  http://semanticscience.org/resource/SIO_010792
resource:SIO_010792 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010786 ;
                    dc:identifier "SIO_010792" ;
                    terms:description "carbon nanofoam is an allotrope of carbon that consists of a low-density cluster-assembly of carbon atoms strung together in a loose three-dimensional web. Each cluster is about 6 nanometers wide and consists of about 4000 carbon atoms linked in graphite-like sheets that are given negative curvature by the inclusion of heptagons among the regular hexagonal pattern."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "carbon nanofoam"@en .


###  http://semanticscience.org/resource/SIO_010793
resource:SIO_010793 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010786 ;
                    dc:identifier "SIO_010793" ;
                    terms:description "chaoite is an allotrope of carbon that is slightly harder than graphite with a reflection colour of grey to white."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "chaoite"@en .


###  http://semanticscience.org/resource/SIO_010794
resource:SIO_010794 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010786 ;
                    dc:identifier "SIO_010794" ;
                    terms:description "glassy carbon is an allotrope of carbon which is widely used as an electrode material in electrochemistry, as well as for high temperature crucibles and as a component of some prosthetic devices."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "glassy carbon"@en .


###  http://semanticscience.org/resource/SIO_010795
resource:SIO_010795 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010786 ;
                    dc:identifier "SIO_010795" ;
                    terms:description "ionsdaleite is a hexagonal allotrope of the carbon allotrope diamond."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "ionsdaleite"@en .



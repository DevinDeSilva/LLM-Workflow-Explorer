                                      owl:onProperty resource:SIO_000210 ;
                                      owl:someValuesFrom resource:SIO_000626
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000332 ;
                                      owl:someValuesFrom resource:SIO_011125
                                    ] ;
                    dc:identifier "SIO_011121" ;

                    rdfs:subClassOf resource:SIO_000706 ;
                    dc:identifier "SIO_000711" ;
                    terms:description "An academic role is a social role that pertains to the academic institution."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "academic role"@en .


###  http://semanticscience.org/resource/SIO_000712
resource:SIO_000712 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000706 ;
                    dc:identifier "SIO_000712" ;
                    terms:description "A medical role is the role of an individual that is a participant in the delivery of medical care."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "medical role"@en .


###  http://semanticscience.org/resource/SIO_000713
resource:SIO_000713 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000712 ;
                    dc:identifier "SIO_000713" ;
                    terms:alternative "physician"@en ;
                    terms:description "A doctor role is the role of an individual who practices medicine, which is concerned with promoting, maintaining or restoring human health through the study, diagnosis, and treatment of disease, injury, and other physical and mental impairments."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "doctor role"@en .


###  http://semanticscience.org/resource/SIO_000714
resource:SIO_000714 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000712 ;
                    dc:identifier "SIO_000714" ;
                    terms:description "A nurse role is the role of an individual that is involved in the protection, promotion, and optimization of health and abilities, prevention of illness and injury, alleviation of suffering through the diagnosis and treatment of human response, and advocacy in the care of individuals, families, communities, and populations."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "nurse role"@en .


###  http://semanticscience.org/resource/SIO_000715
resource:SIO_000715 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000712 ;
                    dc:identifier "SIO_000715" ;
                    terms:description "A patient role is the role of an individual that is the recepient of medical care."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "patient role"@en .


###  http://semanticscience.org/resource/SIO_000716
resource:SIO_000716 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000498 ;
                    dc:identifier "SIO_000716" ;
                    terms:description "A medical practioner is an individual that provides medical care."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "medical practitioner"@en .


###  http://semanticscience.org/resource/SIO_000717
resource:SIO_000717 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000712 ;
                    dc:identifier "SIO_000717" ;
                    terms:description "A dentist role is the role of an individual that that specializes in the diagnosis, prevention, and treatment of diseases and conditions of the oral cavity."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "dentist role"@en .



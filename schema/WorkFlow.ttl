                    rdfs:subClassOf resource:SIO_001212 ;
                    dc:identifier "SIO_001217" ;
                    terms:description "strong is a qualitative intensity value that is more intense than moderate, but less intense than severe."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "strong"@en .



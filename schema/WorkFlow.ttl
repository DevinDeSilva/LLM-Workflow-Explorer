###  http://semanticscience.org/resource/SIO_000282
resource:SIO_000282 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000280 ;
                    dc:identifier "SIO_000282" ;
                    terms:description "XOR, also called exclusive disjunction or (symbolized XOR, EOR, EXOR, or ⊕), is a type of logical disjunction on two operands that results in a value of true if exactly one of the operands has a value of true."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "exclusive disjunction (xor)"@en .



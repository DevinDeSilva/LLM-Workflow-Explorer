                    rdfs:subPropertyOf resource:SIO_000231 ;
                    dc:identifier "SIO_000292" ;
                    terms:description "is target in is a relation between an entity and a process, where the entity is present at the beginning  of the process and undergoes a change or transformation in the process."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;

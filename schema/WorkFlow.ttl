###  http://semanticscience.org/resource/SIO_000094
resource:SIO_000094 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000075 ;
                    dc:identifier "SIO_000094" ;
                    terms:description "An algorithm is an effective method expressed as a finite list of well-defined instructions for calculating a function."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "algorithm"@en .


###  http://semanticscience.org/resource/SIO_000097
resource:SIO_000097 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000602 ;
                    dc:identifier "SIO_000097" ;
                    terms:description "A software entity is a computational entity that can be interpreted by or directly executed by a processing unit."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "software entity"@en .


###  http://semanticscience.org/resource/SIO_000098
resource:SIO_000098 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000097 ;
                    dc:identifier "SIO_000098" ;
                    terms:description "A software method (also called subroutine, subprogram, procedure, method, function, or routine) is software designed to execute a specific task."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "software method"@en .


###  http://semanticscience.org/resource/SIO_000099
resource:SIO_000099 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000097 ;
                    dc:identifier "SIO_000099" ;
                    terms:description "A software module is software composed of a collection of software methods."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "software module"@en .


###  http://semanticscience.org/resource/SIO_000100
resource:SIO_000100 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000097 ;
                    dc:identifier "SIO_000100" ;
                    terms:description "A software library is software composed of a collection of software modules and/or software methods in a form that can be statically or dynamically linked to some software application."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "software library"@en .


###  http://semanticscience.org/resource/SIO_000101
resource:SIO_000101 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000097 ;
                    dc:identifier "SIO_000101" ;
                    terms:description "A software application is software that can be directly executed by some processing unit."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "software application"@en .


###  http://semanticscience.org/resource/SIO_000102
resource:SIO_000102 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000101 ;
                    dc:identifier "SIO_000102" ;
                    terms:description "A software interpreter is a software application that executes some specified input software."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "software interpreter"@en .


###  http://semanticscience.org/resource/SIO_000103
resource:SIO_000103 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000097 ;
                    dc:identifier "SIO_000103" ;
                    terms:description "A software script is software whose instructions can be executed using a software interpreter."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "software script"@en .


###  http://semanticscience.org/resource/SIO_000104
resource:SIO_000104 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000078 ;
                    dc:identifier "SIO_000104" ;
                    terms:description "Language is a language entity which is the result of encoding and decoding information through systematic creation and usage of systems of symbols, each pairing a specific sign with an intended meaning, established through social conventions"@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "language"@en .



                                                    rdfs:label "Global Explanation" .


###  https://purl.org/heals/eo#GlobalExplanationType
<https://purl.org/heals/eo#GlobalExplanationType> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://purl.org/heals/eo#ExplanationType> ;
                                                  rdfs:label "Type - Global Explanation" .


###  https://purl.org/heals/eo#HighLevelFeatureLearningMethod
<https://purl.org/heals/eo#HighLevelFeatureLearningMethod> rdf:type owl:Class ;
                                                           rdfs:subClassOf <https://purl.org/heals/eo#ExplanationMethod> ,
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty resource:SIO_000229 ;
                                                                             owl:someValuesFrom <https://purl.org/heals/eo#GlobalExplanationOutput>
                                                                           ] ;
                                                           dc:description "Methods that learn high-level features in an unsupervised manner through variational autoencoder or generative adversarial network frameworks would naturally fall under the data followed by features category. Even supervised methods of learning high-level interpretable features would lie in this category." ;
                                                           terms:source "Arya, V., Bellamy, R. K., Chen, P. Y., Dhurandhar, A., Hind, M., Hoffman, S. C., ... & Zhang, Y. (2019). One explanation does not fit all: A toolkit and taxonomy of ai explainability techniques. arXiv preprint arXiv:1909.03012." ;
                                                           rdfs:label "High level feature learning method" .


###  https://purl.org/heals/eo#ImpactExplanation
<https://purl.org/heals/eo#ImpactExplanation> rdf:type owl:Class ;
                                              owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                    owl:onProperty <http://linkedu.eu/dedalo/explanationPattern.owl#isBasedOn> ;
                                                                    owl:someValuesFrom [ owl:intersectionOf ( <https://purl.org/heals/eo#SystemRecommendation>
                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                owl:onProperty resource:SIO_000008 ;
                                                                                                                owl:someValuesFrom resource:SIO_001384
                                                                                                              ]
                                                                                                            ) ;
                                                                                         rdf:type owl:Class
                                                                                       ]
                                                                  ] ;
                                              rdfs:subClassOf <http://linkedu.eu/dedalo/explanationPattern.owl#Explanation> ;
                                              dc:description "This type of explanation concerns the impact that the use of an ML system and its decisions has or may have on an individual and on a wider society. This type of explanation gives individuals some power and control over their involvement in ML-assisted decisions. By understanding the possible consequences of the decision, an individual can better assess their participation in the process and how the outcomes of the decision may affect them. Therefore, this type of explanation is often suited to delivery before an ML-assisted decision is made." ;
                                              terms:source "Cunningham P, Doyle D, Loughrey J. An evaluation of the usefulness of case-based explanation. In: International Conference on Case-Based Reasoning. Springer; 2003. p. 122–130." ;
                                              rdfs:label "Impact Explanation" ;
                                              skos:example "What is the impact of a system recommendation?" .


###  https://purl.org/heals/eo#InductiveTask
<https://purl.org/heals/eo#InductiveTask> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://purl.org/heals/eo#AITask> ;
                                          dc:description "Induction is able to match single statement to single statement and, therefore, to match a single statement derived as a prediction from a hypothesis with a single statement describing a portion of the real state of airs in the patient." ;
                                          terms:source "Stefanelli, M., & Ramoni, M. (1992). Epistemological constraints on medical knowledge-based systems. In Advanced models of cognition for medical training and practice (pp. 3-20). Springer, Berlin, Heidelberg." ;
                                          rdfs:label "Inductive Task" .


###  https://purl.org/heals/eo#InteractiveExplanation
<https://purl.org/heals/eo#InteractiveExplanation> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://purl.org/heals/eo#ModelExplanationOutputs> ,
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty <http://purl.org/heals/eo#hasExplanationType> ;
                                                                     owl:someValuesFrom <https://purl.org/heals/eo#InteractiveExplanationType>
                                                                   ] ;
                                                   rdfs:label "Interactive Explanation" .


###  https://purl.org/heals/eo#InteractiveExplanationType
<https://purl.org/heals/eo#InteractiveExplanationType> rdf:type owl:Class ;
                                                       rdfs:subClassOf <https://purl.org/heals/eo#ExplanationType> ;
                                                       rdfs:label "Type - Interactive Explanation" .


###  https://purl.org/heals/eo#InterprationAndExplanationTask
<https://purl.org/heals/eo#InterprationAndExplanationTask> rdf:type owl:Class ;
                                                           rdfs:subClassOf <https://purl.org/heals/eo#AITask> ,
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty prov:used ;
                                                                             owl:someValuesFrom <https://purl.org/heals/eo#ExplanationMethod>
                                                                           ] ;
                                                           dc:description "a task that produces interpretations or explanations, which are an account of the system, its workings, the implicit and explicit knowledge it uses to arrive at conclusions in general and the specific decision at hand, that is sensitive to the end-user’s understanding, context, and current needs." ;
                                                           terms:source "Chari, S., Gruen, D., Seneviratne, O.W., & McGuinness, D.L. (2020). Directions for Explainable Knowledge-Enabled Systems. Knowledge Graphs for eXplainable Artificial Intelligence." ;
                                                           rdfs:label "Interpretation and Explanation Task" .


###  https://purl.org/heals/eo#KnowledgeBasedSystems
<https://purl.org/heals/eo#KnowledgeBasedSystems> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://purl.org/heals/eo#ArtificialIntelligenceMethod> ;
                                                  rdfs:label "Knowledge based Systems" .


###  https://purl.org/heals/eo#KnowledgeDistillationMethod
<https://purl.org/heals/eo#KnowledgeDistillationMethod> rdf:type owl:Class ;
                                                        rdfs:subClassOf <https://purl.org/heals/eo#ExplanationMethod> ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty resource:SIO_000229 ;
                                                                          owl:someValuesFrom <https://purl.org/heals/eo#GlobalExplanationOutput>
                                                                        ] ;
                                                        dc:description "Knowledge distillation-type approaches, which learn a simpler model based on a complex model’s predictions, would be considered as global interpretations that are learned using a post-hoc surrogate model." ;
                                                        terms:source "Arya, V., Bellamy, R. K., Chen, P. Y., Dhurandhar, A., Hind, M., Hoffman, S. C., ... & Zhang, Y. (2019). One explanation does not fit all: A toolkit and taxonomy of ai explainability techniques. arXiv preprint arXiv:1909.03012." ;
                                                        rdfs:label "Knowledge Distillation Method" .


###  https://purl.org/heals/eo#KnowledgeExtractionTask
<https://purl.org/heals/eo#KnowledgeExtractionTask> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://purl.org/heals/eo#AITask> ;
                                                    dc:description "a task of extracting pre-specified types of facts from written texts or speech transcripts, and converting them into structured representations (e.g., databases)." ;
                                                    terms:source "Ji H. (2009) Information Extraction. In: LIU L., ÖZSU M.T. (eds) Encyclopedia of Database Systems. Springer, Boston, MA. https://doi.org/10.1007/978-0-387-39940-9_204" ;
                                                    resource:hasSynonym "Information Extraction" ;
                                                    rdfs:label "Knowledge Extraction Task" .


###  https://purl.org/heals/eo#LocalExplanation
<https://purl.org/heals/eo#LocalExplanation> rdf:type owl:Class ;
                                             owl:equivalentClass [ rdf:type owl:Class ;
                                                                   owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty resource:SIO_000232 ;
                                                                                   owl:someValuesFrom <https://purl.org/heals/eo#ExemplarMethods>
                                                                                 ]
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty resource:SIO_000232 ;
                                                                                   owl:someValuesFrom <https://purl.org/heals/eo#RationaleProvidingMethods>
                                                                                 ]
                                                                               )
                                                                 ] ;
                                             rdfs:subClassOf <https://purl.org/heals/eo#ModelExplanationOutputs> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.org/heals/eo#hasExplanationType> ;
                                                               owl:someValuesFrom <https://purl.org/heals/eo#LocalExplanationType>
                                                             ] ;
                                             rdfs:label "Local Explanation" .


###  https://purl.org/heals/eo#LocalExplanationType
<https://purl.org/heals/eo#LocalExplanationType> rdf:type owl:Class ;
                                                 rdfs:subClassOf <https://purl.org/heals/eo#ExplanationType> ;
                                                 rdfs:label "Type - Local Explanation" .


###  https://purl.org/heals/eo#LookupTask
<https://purl.org/heals/eo#LookupTask> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://purl.org/heals/eo#AITask> ;
                                       dc:description "Looks through a row or column for a key and returns the value of the cell in a result range located in the same position as the search row or column" ;
                                       terms:source "https://support.google.com/docs/answer/3256570?hl=en" ;
                                       rdfs:label "Lookup Task" .


###  https://purl.org/heals/eo#Mechanistic_Explanation
<https://purl.org/heals/eo#Mechanistic_Explanation> rdf:type owl:Class ;
                                                    owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <http://linkedu.eu/dedalo/explanationPattern.owl#isBasedOn> ;
                                                                          owl:someValuesFrom [ owl:intersectionOf ( <https://purl.org/heals/eo#ScientificKnowledge>
                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                      owl:onProperty prov:wasGeneratedBy ;
                                                                                                                      owl:someValuesFrom <https://purl.org/heals/eo#ScientificMethod>
                                                                                                                    ]
                                                                                                                  ) ;
                                                                                               rdf:type owl:Class
                                                                                             ]
                                                                        ] ;
                                                    rdfs:subClassOf <https://purl.org/heals/eo#scientificExplanation> ;
                                                    dc:description "a mechanistic explanation involves presenting a model of the mechanism (the explanans) responsible for some phenomenon of interest (the explanandum). A mechanism is an entity or structure, such as an organ (though a mechanism need not be delineated by such clear physical boundaries) that performs a function by virtue of its component parts, operations and, importantly, their spatial and temporal organisation (Bechtel & Abrahamsen 2005: 421–23). That is, a mechanism does not just consist in its physical parts, but in the ‘organised interplay’ of the activities of those parts (Soom 2012: 656). Examples of phenomena (i.e.,functions or behaviours performed by mechanisms) include such things as the heart’s pumping blood, metabolism and memory." ;
                                                    terms:source "Dessaix, D. Mechanistic Explanation: Some Limits and their Significance. The ANU Undergraduate Research Journal, 51." ;
                                                    rdfs:label "Mechanistic Explanation" ;
                                                    skos:example "Addresses a question of the form, \"What is a biological basis for this recommendation?\"" .


###  https://purl.org/heals/eo#ModelExplanationOutputs
<https://purl.org/heals/eo#ModelExplanationOutputs> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://purl.org/heals/eo#SystemRecommendation> ,
                                                                    [ rdf:type owl:Restriction ;

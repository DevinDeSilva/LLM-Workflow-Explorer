                    rdfs:subClassOf resource:SIO_001427 ;
                    dc:identifier "SIO_001426" ;
                    terms:description "an oligopeptide is an organic polymer composed of fewer than 10 or 15 amino acids."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "oligopeptide"@en .



                    rdfs:subClassOf resource:SIO_000052 ;
                    dc:identifier "SIO_000074" ;
                    terms:description "A unit of measurement is a definite magnitude of a physical quantity, defined and adopted by convention and/or by law, that is used as a standard for measurement of the same physical quantity."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "unit of measurement"@en .



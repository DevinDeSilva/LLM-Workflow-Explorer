                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty resource:SIO_000008 ;
                                                                 owl:someValuesFrom resource:SIO_001243
                                                               ] ;
                                               dc:description "a statistical value that backs and quantifies a recommendation" ;
                                               rdfs:label "Numerical Evidence" .



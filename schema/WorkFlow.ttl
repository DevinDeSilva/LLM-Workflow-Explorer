                    rdfs:subClassOf resource:SIO_000564 ;
                    dc:identifier "SIO_000571" ;
                    terms:description "Brownian motion is the seemlingly random movement of particles suspended in a fluid."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "brownian motion"@en .


###  http://semanticscience.org/resource/SIO_000572
resource:SIO_000572 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000564 ;
                    dc:identifier "SIO_000572" ;
                    terms:description "osmosis is the movement of water molecules through a selectively-permeable membrane down a water potential gradient."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "osmosis"@en .


###  http://semanticscience.org/resource/SIO_000573
resource:SIO_000573 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000570 ;
                    dc:identifier "SIO_000573" ;
                    terms:description "passive movement is the process in which an object is spatially displaced without an expenditure of energy contained in molecular bonds." ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "passive movement"@en .



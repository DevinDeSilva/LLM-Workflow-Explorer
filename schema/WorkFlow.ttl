resource:hasSynonym rdf:type owl:AnnotationProperty ;
                    dc:identifier "hasSynonym" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> .


###  http://semanticscience.org/resource/similarTo
resource:similarTo rdf:type owl:AnnotationProperty ;
                   dc:identifier "similarTo" ;
                   rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> .


###  http://semanticscience.org/resource/subset
resource:subset rdf:type owl:AnnotationProperty ;
                dc:identifier "subset" ;
                rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> .


###  http://www.w3.org/2000/01/rdf-schema#comment
rdfs:comment rdf:type owl:AnnotationProperty ;
             rdfs:comment ""@en ;
             rdfs:isDefinedBy prov: ,
                              <http://www.w3.org/ns/prov-o#> .


###  http://www.w3.org/2000/01/rdf-schema#isDefinedBy
rdfs:isDefinedBy rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#label
rdfs:label rdf:type owl:AnnotationProperty ;
           rdfs:comment ""@en ;
           rdfs:isDefinedBy prov: ,
                            <http://www.w3.org/ns/prov-o#> .


###  http://www.w3.org/2000/01/rdf-schema#seeAlso
rdfs:seeAlso rdf:type owl:AnnotationProperty ;
             rdfs:comment ""@en .


###  http://www.w3.org/2002/07/owl#versionInfo
owl:versionInfo rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty ;
                dc:identifier "core#exactMatch" .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty ;
             dc:identifier "core#example" .


###  http://www.w3.org/TR/prov-o/used
prov-o:used rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#aq
prov:aq rdf:type owl:AnnotationProperty ;
        rdfs:isDefinedBy prov: ,
                         <http://www.w3.org/ns/prov-o#> ;
        rdfs:subPropertyOf rdfs:seeAlso .


###  http://www.w3.org/ns/prov#category
prov:category rdf:type owl:AnnotationProperty ;
              rdfs:comment "Classify prov-o terms into three categories, including 'starting-point', 'qualifed', and 'extended'. This classification is used by the prov-o html document to gently introduce prov-o terms to its users. "@en ;
              rdfs:isDefinedBy prov: ,
                               <http://www.w3.org/ns/prov-o#> .


###  http://www.w3.org/ns/prov#component
prov:component rdf:type owl:AnnotationProperty ;
               rdfs:comment "Classify prov-o terms into six components according to prov-dm, including 'agents-responsibility', 'alternate', 'annotations', 'collections', 'derivations', and 'entities-activities'. This classification is used so that readers of prov-o specification can find its correspondence with the prov-dm specification."@en ;
               rdfs:isDefinedBy prov: ,
                                <http://www.w3.org/ns/prov-o#> .


###  http://www.w3.org/ns/prov#constraints
prov:constraints rdf:type owl:AnnotationProperty ;
                 rdfs:comment "A reference to the principal section of the PROV-CONSTRAINTS document that describes this concept."@en ;
                 rdfs:isDefinedBy prov: ,
                                  <http://www.w3.org/ns/prov-o#> ;
                 rdfs:subPropertyOf rdfs:seeAlso .


###  http://www.w3.org/ns/prov#definition
prov:definition rdf:type owl:AnnotationProperty ;
                rdfs:comment "A definition quoted from PROV-DM or PROV-CONSTRAINTS that describes the concept expressed with this OWL term."@en ;
                rdfs:isDefinedBy prov: ,
                                 <http://www.w3.org/ns/prov-o#> .


###  http://www.w3.org/ns/prov#dm
prov:dm rdf:type owl:AnnotationProperty ;
        rdfs:comment "A reference to the principal section of the PROV-DM document that describes this concept."@en ;
        rdfs:isDefinedBy prov: ,
                         <http://www.w3.org/ns/prov-o#> ;
        rdfs:subPropertyOf rdfs:seeAlso .


###  http://www.w3.org/ns/prov#editorialNote
prov:editorialNote rdf:type owl:AnnotationProperty ;
                   rdfs:comment "A note by the OWL development team about how this term expresses the PROV-DM concept, or how it should be used in context of semantic web or linked data."@en ;
                   rdfs:isDefinedBy prov: ,
                                    <http://www.w3.org/ns/prov-o#> .


###  http://www.w3.org/ns/prov#editorsDefinition
prov:editorsDefinition rdf:type owl:AnnotationProperty ;
                       rdfs:comment "When the prov-o term does not have a definition drawn from prov-dm, and the prov-o editor provides one."@en ;
                       rdfs:isDefinedBy prov: ,
                                        <http://www.w3.org/ns/prov-o#> ;
                       rdfs:subPropertyOf prov:definition .


###  http://www.w3.org/ns/prov#inverse
prov:inverse rdf:type owl:AnnotationProperty ;
             rdfs:comment "PROV-O does not define all property inverses. The directionalities defined in PROV-O should be given preference over those not defined. However, if users wish to name the inverse of a PROV-O property, the local name given by prov:inverse should be used."@en ;
             rdfs:isDefinedBy prov: ,
                              <http://www.w3.org/ns/prov-o#> ;
             rdfs:seeAlso <http://www.w3.org/TR/prov-o/#names-of-inverse-properties> .


###  http://www.w3.org/ns/prov#n
prov:n rdf:type owl:AnnotationProperty ;
       rdfs:comment "A reference to the principal section of the PROV-DM document that describes this concept."@en ,
                    "A reference to the principal section of the PROV-M document that describes this concept."@en ;
       rdfs:isDefinedBy prov: ,
                        <http://www.w3.org/ns/prov-o#> ;
       rdfs:subPropertyOf rdfs:seeAlso .


###  http://www.w3.org/ns/prov#order
prov:order rdf:type owl:AnnotationProperty ;
           rdfs:comment "The position that this OWL term should be listed within documentation. The scope of the documentation (e.g., among all terms, among terms within a prov:category, among properties applying to a particular class, etc.) is unspecified."@en ;
           rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> .


###  http://www.w3.org/ns/prov#qualifiedForm
prov:qualifiedForm rdf:type owl:AnnotationProperty ;
                   rdfs:comment """This annotation property links a subproperty of prov:wasInfluencedBy with the subclass of prov:Influence and the qualifying property that are used to qualify it. 

Example annotation:

    prov:wasGeneratedBy prov:qualifiedForm prov:qualifiedGeneration, prov:Generation .

Then this unqualified assertion:

    :entity1 prov:wasGeneratedBy :activity1 .

can be qualified by adding:

   :entity1 prov:qualifiedGeneration :entity1Gen .
   :entity1Gen 
       a prov:Generation, prov:Influence;
       prov:activity :activity1;
       :customValue 1337 .

Note how the value of the unqualified influence (prov:wasGeneratedBy :activity1) is mirrored as the value of the prov:activity (or prov:entity, or prov:agent) property on the influence class."""@en ;
                   rdfs:isDefinedBy prov: ,
                                    <http://www.w3.org/ns/prov-o#> ;
                   rdfs:subPropertyOf rdfs:seeAlso .


###  http://www.w3.org/ns/prov#sharesDefinitionWith
prov:sharesDefinitionWith rdf:type owl:AnnotationProperty ;
                          rdfs:isDefinedBy prov: ,
                                           <http://www.w3.org/ns/prov-o#> ;
                          rdfs:subPropertyOf rdfs:seeAlso .


###  http://www.w3.org/ns/prov#specializationOf
prov:specializationOf rdf:type owl:AnnotationProperty ;
                      rdfs:range prov:Entity .


###  http://www.w3.org/ns/prov#todo
prov:todo rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#unqualifiedForm
prov:unqualifiedForm rdf:type owl:AnnotationProperty ;
                     rdfs:comment "Classes and properties used to qualify relationships are annotated with prov:unqualifiedForm to indicate the property used to assert an unqualified provenance relation."@en ;
                     rdfs:isDefinedBy prov: ,
                                      <http://www.w3.org/ns/prov-o#> ;
                     rdfs:subPropertyOf rdfs:seeAlso .


###  http://www.w3.org/ns/prov#wasRevisionOf
prov:wasRevisionOf rdf:type owl:AnnotationProperty ;
                   rdfs:range prov:Entity .


###  http://xmlns.com/foaf/0.1/homepage
foaf:homepage rdf:type owl:AnnotationProperty ;
              dc:identifier "homepage" .


#################################################################
#    Object Properties
#################################################################

###  http://linkedu.eu/dedalo/data/interacts
<http://linkedu.eu/dedalo/data/interacts> rdf:type owl:ObjectProperty .


###  http://linkedu.eu/dedalo/explanationPattern.owl#isBasedOn
<http://linkedu.eu/dedalo/explanationPattern.owl#isBasedOn> rdf:type owl:ObjectProperty ;
                                                            rdfs:subPropertyOf resource:SIO_001403 ;
                                                            rdfs:label "is based on" .


###  http://purl.dataone.org/provone/2015/01/15/ontology#connectsTo
<http://purl.dataone.org/provone/2015/01/15/ontology#connectsTo> rdf:type owl:ObjectProperty ;
                                                                 rdfs:domain <http://purl.dataone.org/provone/2015/01/15/ontology#Port> ;
                                                                 rdfs:range <http://purl.dataone.org/provone/2015/01/15/ontology#Channel> ;
                                                                 rdfs:comment """Specifies the Channel that the given Port connects to, 
          typically with an output Port connected to an input Port.""" ;
                                                                 rdfs:label "connectsTo" ;
                                                                 prov:category "workflow-specification" .


###  http://purl.dataone.org/provone/2015/01/15/ontology#controlledBy
<http://purl.dataone.org/provone/2015/01/15/ontology#controlledBy> rdf:type owl:ObjectProperty ;
                                                                   rdfs:domain <http://purl.dataone.org/provone/2015/01/15/ontology#Program> ;
                                                                   rdfs:range <http://purl.dataone.org/provone/2015/01/15/ontology#Controller> ;
                                                                   rdfs:comment "Relates a Program to the controller it is controlled by." ;
                                                                   rdfs:label "controlledBy" ;
                                                                   prov:category "workflow-specification" .


###  http://purl.dataone.org/provone/2015/01/15/ontology#controls
<http://purl.dataone.org/provone/2015/01/15/ontology#controls> rdf:type owl:ObjectProperty ;
                                                               rdfs:domain <http://purl.dataone.org/provone/2015/01/15/ontology#Controller> ;
                                                               rdfs:range <http://purl.dataone.org/provone/2015/01/15/ontology#Program> ;
                                                               rdfs:comment "Relates a Controller to its destination Program." ;
                                                               rdfs:label "controls" ;
                                                               prov:category "workflow-specification" .


###  http://purl.dataone.org/provone/2015/01/15/ontology#hadEntity
<http://purl.dataone.org/provone/2015/01/15/ontology#hadEntity> rdf:type owl:ObjectProperty ;
                                                                rdfs:domain prov:Generation ,
                                                                            prov:Usage ;
                                                                rdfs:range prov:Entity ;
                                                                rdfs:comment "Enables the specification of an Entity used by a particular Usage or generated by a particular Generation. This allows for further qualification of the prov:used and prov:wasGeneratedBy properties in the context of an Execution." ;
                                                                rdfs:label "hadEntity" ;
                                                                prov:category "trace-specification" .


###  http://purl.dataone.org/provone/2015/01/15/ontology#hadInPort
<http://purl.dataone.org/provone/2015/01/15/ontology#hadInPort> rdf:type owl:ObjectProperty ;
                                                                rdfs:domain prov:Usage ;
                                                                rdfs:range <http://purl.dataone.org/provone/2015/01/15/ontology#Port> ;
                                                                rdfs:comment "Enables the specification of a Port as an input port of a particular Usage. This allows for further qualification of the prov:used property in the context of an Execution." ;
                                                                rdfs:label "hadInPort" ;
                                                                prov:category "workflow-specification" .


###  http://purl.dataone.org/provone/2015/01/15/ontology#hadOutPort
<http://purl.dataone.org/provone/2015/01/15/ontology#hadOutPort> rdf:type owl:ObjectProperty ;
                                                                 rdfs:domain prov:Generation ;
                                                                 rdfs:range <http://purl.dataone.org/provone/2015/01/15/ontology#Port> ;
                                                                 rdfs:comment "Enables the specification of a Port as an output port of a particular Generation. This allows for further qualification of the prov:wasGeneratedBy property in the context of an Execution." ;
                                                                 rdfs:label "hadOutPort" ;
                                                                 prov:category "trace-specification" .


###  http://purl.dataone.org/provone/2015/01/15/ontology#hasDefaultParam
<http://purl.dataone.org/provone/2015/01/15/ontology#hasDefaultParam> rdf:type owl:ObjectProperty ;
                                                                      rdfs:domain <http://purl.dataone.org/provone/2015/01/15/ontology#Port> ;
                                                                      rdfs:range prov:Entity ;
                                                                      rdfs:comment "Specifies that a given Port (likely a semantically typed input port via hasInPort) has a certain Entity item (usually Data) as a default parameter. This enables Workflow instances to be configured." ;
                                                                      rdfs:label "hasDefaultParam" ;
                                                                      prov:category "workflow-specification" .


###  http://purl.dataone.org/provone/2015/01/15/ontology#hasInPort
<http://purl.dataone.org/provone/2015/01/15/ontology#hasInPort> rdf:type owl:ObjectProperty ;
                                                                rdfs:domain <http://purl.dataone.org/provone/2015/01/15/ontology#Program> ;
                                                                rdfs:range <http://purl.dataone.org/provone/2015/01/15/ontology#Port> ,
                                                                           <http://purl.dataone.org/provone/2015/01/15/ontology#Program> ;
                                                                rdfs:comment "Enables the specification of a Port as an input port of a particular Program." ;
                                                                rdfs:label "hasInPort" ;
                                                                prov:category "workflow-specification" .


###  http://purl.dataone.org/provone/2015/01/15/ontology#hasOutPort
<http://purl.dataone.org/provone/2015/01/15/ontology#hasOutPort> rdf:type owl:ObjectProperty ;
                                                                 rdfs:domain <http://purl.dataone.org/provone/2015/01/15/ontology#Program> ;
                                                                 rdfs:range <http://purl.dataone.org/provone/2015/01/15/ontology#Port> ;
                                                                 rdfs:comment "Enables the specification of a Port as an output port of a particular Program." ;
                                                                 rdfs:label "hasOutPort" ;
                                                                 prov:category "workflow-specification" .


###  http://purl.dataone.org/provone/2015/01/15/ontology#hasSubProgram
<http://purl.dataone.org/provone/2015/01/15/ontology#hasSubProgram> rdf:type owl:ObjectProperty ;
                                                                    rdfs:domain <http://purl.dataone.org/provone/2015/01/15/ontology#Program> ;
                                                                    rdfs:range <http://purl.dataone.org/provone/2015/01/15/ontology#Program> ;
                                                                    rdfs:comment "Specifies the recursive composition of Programs, where a parent Program includes a child Program as part of its specification." ;
                                                                    rdfs:label "hasSubProgram" ;
                                                                    prov:category "workflow-specification" .


###  http://purl.dataone.org/provone/2015/01/15/ontology#wasPartOf
<http://purl.dataone.org/provone/2015/01/15/ontology#wasPartOf> rdf:type owl:ObjectProperty ;
                                                                rdfs:domain <http://purl.dataone.org/provone/2015/01/15/ontology#Execution> ;
                                                                rdfs:range <http://purl.dataone.org/provone/2015/01/15/ontology#Execution> ;
                                                                rdfs:comment "Specifies the structure of Execution instances, where a parent Execution (associated with a Workflow) had child Executions (associated with Programs and subworkflows)." ;
                                                                rdfs:label "wasPartOf" ;
                                                                prov:category "trace-specification" .


###  http://purl.org/heals/eo#hasCharacteristic
<http://purl.org/heals/eo#hasCharacteristic> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf resource:SIO_000008 ;
                                             owl:inverseOf <http://purl.org/heals/eo#isCharacteristicOf> ;
                                             rdfs:range <http://purl.org/heals/eo#Characteristic> ;
                                             rdfs:label "has characteristic" .


###  http://purl.org/heals/eo#hasExplanationType
<http://purl.org/heals/eo#hasExplanationType> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <http://purl.org/heals/eo#hasCharacteristic> .


###  http://purl.org/heals/eo#hasGoal
<http://purl.org/heals/eo#hasGoal> rdf:type owl:ObjectProperty .


###  http://purl.org/heals/eo#hasParameter
<http://purl.org/heals/eo#hasParameter> rdf:type owl:ObjectProperty ;
                                        rdfs:subPropertyOf <http://purl.org/heals/eo#hasCharacteristic> ;
                                        rdfs:range <http://purl.org/heals/eo#Parameter> ;
                                        rdfs:label "has parameter" .


###  http://purl.org/heals/eo#hasPrimaryParameter
<http://purl.org/heals/eo#hasPrimaryParameter> rdf:type owl:ObjectProperty ;
                                               rdfs:subPropertyOf <http://purl.org/heals/eo#hasParameter> ;
                                               rdfs:label "has primary parameter" .


###  http://purl.org/heals/eo#hasSecondaryParameter
<http://purl.org/heals/eo#hasSecondaryParameter> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf <http://purl.org/heals/eo#hasParameter> ;
                                                 rdfs:label "has secondary parameter" .


###  http://purl.org/heals/eo#isAvailibleIn
<http://purl.org/heals/eo#isAvailibleIn> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf <http://purl.org/heals/eo#isCharacteristicOf> ,
                                                            <http://purl.org/heals/eo#isSupportedBy> ;
                                         owl:inverseOf <https://purl.org/heals/eo#hasAvailability> ;
                                         rdfs:label "is available in" .


###  http://purl.org/heals/eo#isCharacteristicOf
<http://purl.org/heals/eo#isCharacteristicOf> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf resource:SIO_000011 ;
                                              rdfs:label "is characteristic of" .


###  http://purl.org/heals/eo#isOpposedBy
<http://purl.org/heals/eo#isOpposedBy> rdf:type owl:ObjectProperty ;
                                       rdfs:subPropertyOf resource:SIO_000212 ;
                                       owl:inverseOf <http://purl.org/heals/eo#opposes> ;
                                       rdfs:label "is opposed by" .


###  http://purl.org/heals/eo#isParameterOfType
<http://purl.org/heals/eo#isParameterOfType> rdf:type owl:ObjectProperty .


###  http://purl.org/heals/eo#isSupportedBy
<http://purl.org/heals/eo#isSupportedBy> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf resource:SIO_000212 ;
                                         owl:inverseOf <http://purl.org/heals/eo#supports> ;
                                         rdfs:label "is supported by" .


###  http://purl.org/heals/eo#opposes
<http://purl.org/heals/eo#opposes> rdf:type owl:ObjectProperty ;
                                   rdfs:subPropertyOf resource:SIO_000628 ;
                                   rdfs:label "opposes" .


###  http://purl.org/heals/eo#pertainsTo
<http://purl.org/heals/eo#pertainsTo> rdf:type owl:ObjectProperty .


###  http://purl.org/heals/eo#recommendedBy
<http://purl.org/heals/eo#recommendedBy> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf resource:SIO_000212 ;
                                         owl:inverseOf <http://purl.org/heals/eo#recommends> ;
                                         rdfs:label "recommended by" .


###  http://purl.org/heals/eo#recommends
<http://purl.org/heals/eo#recommends> rdf:type owl:ObjectProperty ;
                                      rdfs:subPropertyOf <http://purl.org/heals/eo#isCharacteristicOf> ,
                                                         <http://purl.org/heals/eo#isSupportedBy> ;
                                      rdfs:label "recommends" .


###  http://purl.org/heals/eo#supports
<http://purl.org/heals/eo#supports> rdf:type owl:ObjectProperty ;
                                    rdfs:subPropertyOf resource:SIO_000628 ;
                                    rdfs:label "supports" .


###  http://semanticscience.org/resource/SIO_000001
resource:SIO_000001 rdf:type owl:ObjectProperty ,
                             owl:SymmetricProperty ;
                    rdfs:domain resource:SIO_000000 ;
                    rdfs:range resource:SIO_000000 ;
                    dc:identifier "SIO_000001" ;
                    terms:description "A is related to B iff there is some relation between A and B."@en ;
                    schema:comment "'is related to' is the top level relation in SIO" ;
                    resource:subset "core" ,
                                    "relations+" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is related to"@en .


###  http://semanticscience.org/resource/SIO_000008
resource:SIO_000008 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000001 ;
                    owl:inverseOf resource:SIO_000011 ;
                    rdfs:domain resource:SIO_000000 ;
                    dc:identifier "SIO_000008" ;
                    terms:description "has attribute is a relation that associates a entity with an attribute where an attribute is an intrinsic characteristic such as a quality, capability, disposition, function, or is an externally derived attribute determined from some descriptor (e.g. a quantity, position, label/identifier) either directly or indirectly through generalization of entities of the same type."@en ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "has attribute"@en .


###  http://semanticscience.org/resource/SIO_000011
resource:SIO_000011 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000001 ;
                    dc:identifier "SIO_000011" ;
                    terms:description "is attribute of is a relation that associates an attribute with an entity where an attribute is an intrinsic characteristic such as a quality, capability, disposition, function, or is an externally derived attribute determined from some descriptor (e.g. a quantity, position, label/identifier) either directly or indirectly through generalization of entities of the same type."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is attribute of"@en .


###  http://semanticscience.org/resource/SIO_000020
resource:SIO_000020 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000210 ;
                    owl:inverseOf resource:SIO_000060 ;
                    dc:identifier "SIO_000020" ;
                    terms:description "denotes is a relation between an entity and what it is a sign or indication of, or what specifically means."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "denotes"@en ;
                    skos:example "the symbol '%' denotes a proportion in relation to a whole."@en .


###  http://semanticscience.org/resource/SIO_000028
resource:SIO_000028 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000145 ;
                    owl:inverseOf resource:SIO_000068 ;
                    rdf:type owl:TransitiveProperty ,
                             owl:ReflexiveProperty ;
                    dc:identifier "SIO_000028" ;
                    terms:description "has part is a transitive, reflexive and antisymmetric relation between a whole and itself or a whole and its part."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "has part"@en ;
                    skos:example "a collection of cars has as a car as a part;a car has an engine as a part; a car has a piston as a part;"@en .


###  http://semanticscience.org/resource/SIO_000029
resource:SIO_000029 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000096 ;
                    owl:inverseOf resource:SIO_000679 ;
                    rdfs:domain resource:SIO_000418 ;
                    dc:identifier "SIO_000029" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is time boundary of"@en .


###  http://semanticscience.org/resource/SIO_000053
resource:SIO_000053 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000028 ;
                    owl:inverseOf resource:SIO_000093 ;
                    rdf:type owl:AsymmetricProperty ,
                             owl:IrreflexiveProperty ;
                    dc:identifier "SIO_000053" ;
                    terms:description "has proper part is an antisymmetric, irreflexive (normally transitive) relation between a whole and a distinct part."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "has proper part"@en ;
                    skos:example "a car has an engine as a proper part; a car has a piston as a proper part;"@en .


###  http://semanticscience.org/resource/SIO_000054
resource:SIO_000054 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000053 ;
                    owl:inverseOf resource:SIO_000096 ;
                    dc:identifier "SIO_000054" ;
                    terms:description "has boundary is a mereological relation between a whole and boundary located at its periphery."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "has boundary"@en ;
                    skos:example "the surface of an apple is a 2D boundary of the apple."@en .


###  http://semanticscience.org/resource/SIO_000059
resource:SIO_000059 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000008 ;
                    owl:inverseOf resource:SIO_000095 ;
                    rdf:type owl:IrreflexiveProperty ;
                    rdfs:domain resource:SIO_000616 ;
                    dc:identifier "SIO_000059" ;
                    terms:description "has member is a mereological relation between a collection and an item."@en ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "has member"@en ;
                    skos:example "a collection of cars has as a car as a member"@en .


###  http://semanticscience.org/resource/SIO_000060
resource:SIO_000060 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000205 ;
                    dc:identifier "SIO_000060" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is denoted by"@en .


###  http://semanticscience.org/resource/SIO_000061
resource:SIO_000061 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000322 ;
                    owl:inverseOf resource:SIO_000145 ;
                    rdf:type owl:TransitiveProperty ;
                    dc:identifier "SIO_000061" ;
                    terms:description "A is located in B iff the spatialtemporial region occupied by A is part of the spatialtemporal region occupied by B. [T][R]"@en ;
                    resource:equivalentTo "OBO_REL:located_in" ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is located in"@en ;
                    skos:example "A parasite in the interior of a person's intestine is located in their intestinal lumen."@en .


###  http://semanticscience.org/resource/SIO_000062
resource:SIO_000062 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000322 ;
                    owl:inverseOf resource:SIO_000132 ;
                    rdfs:range resource:SIO_000006 ;
                    dc:identifier "SIO_000062" ;
                    terms:description "is participant in is a relation that describes the participation of the subject in the (processual) object."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is participant in"@en ;
                    skos:example "a car is a participant in a car race; glucose is a participant in glycolysis"@en .


###  http://semanticscience.org/resource/SIO_000063
resource:SIO_000063 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000062 ;
                    owl:inverseOf resource:SIO_000139 ;
                    dc:identifier "SIO_000063" ;
                    terms:description "is agent in is a relation between an entity and a process, where the entity is present throughout the process, no permanent material change occurs, and is a causal participant in the process."@en ;
                    resource:subset "sadi"@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is agent in"@en ;
                    skos:example "hexokinase is an agent in the conversion of glucose to glucose-6-phosphate"@en .


###  http://semanticscience.org/resource/SIO_000064
resource:SIO_000064 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000219 ;
                    owl:inverseOf resource:SIO_000066 ;
                    dc:identifier "SIO_000064" ;
                    terms:description "is provider of is a relation between a source and the entity it makes available."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is provider of"@en .


###  http://semanticscience.org/resource/SIO_000066
resource:SIO_000066 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000253 ;
                    dc:identifier "SIO_000066" ;
                    terms:description "is provided by is a relation between an entity and the entity that provides it."@en ;
                    resource:equivalentTo "dc:source" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "has provider"@en .


###  http://semanticscience.org/resource/SIO_000068
resource:SIO_000068 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000061 ;
                    rdf:type owl:TransitiveProperty ,
                             owl:ReflexiveProperty ;
                    dc:identifier "SIO_000068" ;
                    terms:description "is part of is a transitive, reflexive and anti-symmetric mereological relation between a whole and itself or a part and its whole."@en ;
                    resource:equivalentTo "OBO_REL:part_of" ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is part of"@en .


###  http://semanticscience.org/resource/SIO_000093
resource:SIO_000093 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000068 ;
                    rdf:type owl:AsymmetricProperty ,
                             owl:IrreflexiveProperty ;
                    dc:identifier "SIO_000093" ;
                    terms:description "is proper part of is an asymmetric, irreflexive (normally transitive) relation between a part and its distinct whole."@en ;
                    resource:equivalentTo "OBO_REL:proper_part_of" ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is proper part of"@en .


###  http://semanticscience.org/resource/SIO_000095
resource:SIO_000095 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000011 ;
                    dc:identifier "SIO_000095" ;
                    terms:description "is member of is a mereological relation between a item and a collection."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is member of"@en .


###  http://semanticscience.org/resource/SIO_000096
resource:SIO_000096 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000093 ;
                    dc:identifier "SIO_000096" ;
                    terms:description "is boundary of is a mereological relation between a boundary located at the periphery of a whole."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is boundary of"@en .


###  http://semanticscience.org/resource/SIO_000128
resource:SIO_000128 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000061 ;
                    owl:inverseOf resource:SIO_000202 ;
                    rdf:type owl:TransitiveProperty ;
                    dc:identifier "SIO_000128" ;
                    terms:description "A is contained in B iff the spatial region occupied by A is part of the spatial region occupied by B and A is not part of B. [T]"@en ;
                    resource:equivalentTo "OBO_REL:contained_in" ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is contained in"@en .


###  http://semanticscience.org/resource/SIO_000132
resource:SIO_000132 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000322 ;
                    rdfs:domain resource:SIO_000006 ;
                    dc:identifier "SIO_000132" ;
                    terms:description "has participant is a relation that describes the participation of the object in the (processual) subject."@en ;
                    resource:equivalentTo "OBO_REL:has_participant" ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "has participant"@en .


###  http://semanticscience.org/resource/SIO_000139
resource:SIO_000139 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000132 ;
                    dc:identifier "SIO_000139" ;
                    terms:description "has agent is a relation between a process and an entity, where the entity is present throughout the process and is a causal participant in the process."@en ;
                    resource:equivalentTo "OBO_REL:has_agent" ;
                    resource:subset "sadi"@en ,
                                    "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "has agent"@en .


###  http://semanticscience.org/resource/SIO_000145
resource:SIO_000145 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000322 ;
                    rdf:type owl:TransitiveProperty ;
                    dc:identifier "SIO_000145" ;
                    terms:description "A is location of B iff the spatialtemporal region occupied by A has the spatialtemporal region occupied by B as a part. [T][R]"@en ;
                    resource:subset "nlp+" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is location of"@en .


###  http://semanticscience.org/resource/SIO_000202
resource:SIO_000202 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000145 ;
                    rdf:type owl:TransitiveProperty ;
                    dc:identifier "SIO_000202" ;
                    terms:description "A contains B iff the spatial region occupied by A has the spatial region occupied by B as a part, and B is not part of A. [T]"@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "contains"@en .


###  http://semanticscience.org/resource/SIO_000203
resource:SIO_000203 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000322 ;
                    rdf:type owl:SymmetricProperty ,
                             owl:TransitiveProperty ;
                    dc:identifier "SIO_000203" ;
                    terms:alternative "interacts with"@en ;
                    terms:description "A is connected to B iff there exists a fiat, material or temporal path between A and B. [S][T]"@en ;
                    resource:subset "core" ,
                                    "nlp" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "is connected to"@en .


###  http://semanticscience.org/resource/SIO_000204
resource:SIO_000204 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000322 ;
                    rdf:type owl:SymmetricProperty ;
                    dc:identifier "SIO_000204" ;
                    terms:description "A is adjacent to B iff there is a small, but non-zero distance between A and B"@en ;
                    resource:equivalentTo "OBO_REL:adjacent_to" ;
                    resource:subset "core" ,

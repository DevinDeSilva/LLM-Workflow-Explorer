###  http://semanticscience.org/resource/SIO_001000
resource:SIO_001000 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001048 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000339 ;
                                      owl:someValuesFrom resource:SIO_001043
                                    ] ;
                    dc:identifier "SIO_001000" ;
                    terms:description "A clinical trial is an intervention trial to determine the safety and efficacy of  medical interventions (e.g., drugs, diagnostics, devices, therapy protocols). "@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "clinical trial"@en .


###  http://semanticscience.org/resource/SIO_001001
resource:SIO_001001 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001024 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000229 ;
                                      owl:someValuesFrom resource:SIO_001003
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000230 ;
                                      owl:someValuesFrom [ owl:intersectionOf ( resource:SIO_010046
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty resource:SIO_000217 ;
                                                                                  owl:someValuesFrom resource:SIO_000758
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ]
                                    ] ;
                    dc:identifier "SIO_001001" ;
                    terms:description "A medical diagnosis (often simply termed diagnosis) refers to the process of attempting to determine or identify a possible disease or disorder."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "medical diagnosis"@en .


###  http://semanticscience.org/resource/SIO_001002
resource:SIO_001002 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001024 ;
                    dc:identifier "SIO_001002" ;
                    terms:description "A differential diagnosis (sometimes abbreviated DDx, ddx, DD, D/Dx, or ΔΔ) is a systematic diagnostic method used to identify the presence of an entity where multiple alternatives are possible (and the process may be termed differential diagnostic procedure), and may also refer to any of the included candidate alternatives (which may also be termed candidate condition)."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "differential diagnosis"@en .


###  http://semanticscience.org/resource/SIO_001003
resource:SIO_001003 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001004 ;
                    dc:identifier "SIO_001003" ;
                    terms:description "A diagnostic opinion is an opinion resulting from a medical diagnostic procedure."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "diagnostic opinion"@en .


###  http://semanticscience.org/resource/SIO_001004
resource:SIO_001004 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000360 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000311 ;
                                      owl:someValuesFrom resource:SIO_001001
                                    ] ;
                    dc:identifier "SIO_001004" ;
                    terms:description "An opinion is a belief that is the result of emotion or interpretation of facts. "@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "opinion"@en .


###  http://semanticscience.org/resource/SIO_001005
resource:SIO_001005 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010013 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000139 ;
                                      owl:someValuesFrom resource:SIO_010038
                                    ] ;
                    dc:identifier "SIO_001005" ;
                    terms:description "A chemical effect is a chemical interaction in which a chemical elicits a marked characteristic of a biological system."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "chemical effect"@en .


###  http://semanticscience.org/resource/SIO_001006
resource:SIO_001006 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001005 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000132 ;
                                      owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                      owl:onClass resource:SIO_010038
                                    ] ;
                    dc:identifier "SIO_001006" ;
                    terms:description "A drug-drug interaction is an interaction in which two drugs interact in such a way to produce a non-additive biological response."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "drug drug interaction"@en .


###  http://semanticscience.org/resource/SIO_001007

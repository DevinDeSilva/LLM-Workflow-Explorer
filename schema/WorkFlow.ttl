                                      owl:onProperty resource:SIO_000093 ;
                                      owl:someValuesFrom resource:SIO_000327
                                    ] ;
                    dc:identifier "SIO_000073" ;
                    terms:description "A polar coordinate is a position characterized by a distance from a fixed point and an angle from a fixed direction."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;

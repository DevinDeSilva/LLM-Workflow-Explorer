###  http://semanticscience.org/resource/SIO_000293
resource:SIO_000293 rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf resource:SIO_000203 ;
                    rdf:type owl:SymmetricProperty ,
                             owl:TransitiveProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( resource:SIO_011125
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty resource:SIO_000068 ;
                                                  owl:someValuesFrom resource:SIO_011125
                                                ]
                                              )
                                ] ;
                    rdfs:range [ rdf:type owl:Class ;
                                 owl:unionOf ( resource:SIO_011125
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty resource:SIO_000068 ;
                                                 owl:someValuesFrom resource:SIO_011125
                                               ]
                                             )
                               ] ;
                    dc:identifier "SIO_000293" ;

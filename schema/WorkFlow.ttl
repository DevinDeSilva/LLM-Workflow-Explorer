                    rdfs:subClassOf resource:SIO_010029 ;
                    owl:disjointWith resource:SIO_010052 ;
                    dc:identifier "SIO_001405" ;
                    terms:description "intersex is a biological sex characterised by birth with genitalia and/or secondary sexual characteristics of indeterminate sex, or which combine features of both sexes."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "intersex"@en .


###  http://semanticscience.org/resource/SIO_001406
resource:SIO_001406 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000048 ;
                    dc:identifier "SIO_001406" ;
                    terms:description "Density (volumetric mass density) is the quantity of mass per unit volume of a substance."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "density"@en .


###  http://semanticscience.org/resource/SIO_001407
resource:SIO_001407 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000045 ;
                    dc:identifier "SIO_001407" ;
                    terms:description "The surface area of a is a measure of the total area that the surface of the object occupies."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "surface area"@en .


###  http://semanticscience.org/resource/SIO_001408
resource:SIO_001408 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001018 ;
                    dc:identifier "SIO_001408" ;
                    terms:description "The aspect ratio of a geometric shape is the ratio of its sizes in different dimensions."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "aspect ratio"@en .


###  http://semanticscience.org/resource/SIO_001409
resource:SIO_001409 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000026 ;
                    dc:identifier "SIO_001409" ;
                    terms:description "object relational quality refers to a quality in relation to one or more objects"@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "object relational quality"@en .


###  http://semanticscience.org/resource/SIO_001410
resource:SIO_001410 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001409 ;
                    dc:identifier "SIO_001410" ;
                    terms:description "synthetic quality is the quality of a manufactured object that has similar properties as naturally occuring objects."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "synthetic quality"@en .


###  http://semanticscience.org/resource/SIO_001411
resource:SIO_001411 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001409 ;
                    dc:identifier "SIO_001411" ;
                    terms:description "sample quality is the quality of an object that is drawn from a larger population."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "sample quality"@en .


###  http://semanticscience.org/resource/SIO_001412
resource:SIO_001412 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001409 ;
                    dc:identifier "SIO_001412" ;
                    terms:description "replica quality is the quality of an object that is an exact copy of another object."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "replica quality"@en .


###  http://semanticscience.org/resource/SIO_001413
resource:SIO_001413 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001018 ;
                    dc:identifier "SIO_001413" ;
                    terms:description "A percentage is a number that is a ratio expressed as a fraction of 100. It is denoted using the percent sign \"%\"."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "percentage"@en .


###  http://semanticscience.org/resource/SIO_001414
resource:SIO_001414 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000257 ;
                    dc:identifier "SIO_001414" ;
                    terms:description "A quantile is a quantity that divides the range of a probability distribution into continuous intervals with equal probabilities, or dividing the observations in a sample in the same way."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "quantile"@en .


###  http://semanticscience.org/resource/SIO_001415
resource:SIO_001415 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001414 ;
                    dc:identifier "SIO_001415" ;
                    terms:description "A percentile (or a centile) is a quantile that divides the given probability distribution, or sample, into 100 equal-sized intervals."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "percentile"@en .


###  http://semanticscience.org/resource/SIO_001416
resource:SIO_001416 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000721 ;
                    dc:identifier "SIO_001416" ;
                    terms:description "a duplicate role is a comparative role that holds when one item is an exact copy of another in a specific set."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "duplicate role"@en .


###  http://semanticscience.org/resource/SIO_001417
resource:SIO_001417 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000721 ;
                    dc:identifier "SIO_001417" ;
                    terms:description "a replicate role is a comparative role that holds  when one item is a reproduction, facsimile, or a copy of another."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "replicate role"@en .



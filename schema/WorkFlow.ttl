                    rdfs:subClassOf resource:SIO_000030 ;
                    dc:identifier "SIO_000989" ;
                    terms:description "A sequence assembly is a sequence that is produced as by the alignment of two or more sequences."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "sequence assembly"@en .


###  http://semanticscience.org/resource/SIO_000991

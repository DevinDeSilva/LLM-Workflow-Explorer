                    dc:identifier "SIO_000107" ;
                    terms:description "A chapter is a document section of a book or thesis."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "chapter"@en .


###  http://semanticscience.org/resource/SIO_000108

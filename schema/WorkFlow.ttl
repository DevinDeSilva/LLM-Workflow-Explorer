                    rdfs:subClassOf resource:SIO_000831 ;
                    dc:identifier "SIO_000819" ;
                    terms:description "boldness is the trait of being willing to undertake things that involve risk or danger."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "boldness"@en .


###  http://semanticscience.org/resource/SIO_000820
resource:SIO_000820 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000820" ;
                    terms:description "boredom is the emotion experience by those not interested in their surroundings or available activities."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "boredom"@en .


###  http://semanticscience.org/resource/SIO_000821
resource:SIO_000821 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000828 ;
                    dc:identifier "SIO_000821" ;
                    terms:description "contempt is disgust towards a lower status individual."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "contempt"@en .


###  http://semanticscience.org/resource/SIO_000822
resource:SIO_000822 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000840 ;
                    dc:identifier "SIO_000822" ;
                    terms:description "contentment is an emotion characterized by acknowledgement and satisfaction of the current state of affairs."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "contentment"@en .


###  http://semanticscience.org/resource/SIO_000823
resource:SIO_000823 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000825 ;
                    dc:identifier "SIO_000823" ;
                    terms:description "curiosity is the strong desire to know or learn something."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "curiosity"@en .


###  http://semanticscience.org/resource/SIO_000824
resource:SIO_000824 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000863 ;
                    dc:identifier "SIO_000824" ;
                    terms:alternative "depressed" ;
                    terms:description "depression is an unpleasant emotion linked to aversion to activity that can affect a person's thoughts, behavior, feelings and physical well-being. Depressed individuals may feel sad, anxious, empty, hopeless, worried, helpless, worthless, guilty, irritable, or restless."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "depression"@en .


###  http://semanticscience.org/resource/SIO_000825
resource:SIO_000825 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000848 ;
                    dc:identifier "SIO_000825" ;
                    terms:description "desire is a strong emotion of wanting to have something or wishing for something to happen."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "desire"@en .


###  http://semanticscience.org/resource/SIO_000826
resource:SIO_000826 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000863 ;
                    dc:identifier "SIO_000826" ;
                    terms:description "despair is depression, hopelessness or lack of hope."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "despair"@en .


###  http://semanticscience.org/resource/SIO_000827
resource:SIO_000827 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000827" ;
                    terms:alternative "disappointed" ,
                                      "disappointing" ;
                    terms:description "disappointment is the feeling of dissatisfaction that follows the failure of expectations or hopes to manifest."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "disappointment"@en .


###  http://semanticscience.org/resource/SIO_000828
resource:SIO_000828 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000844 ;
                    dc:identifier "SIO_000828" ;
                    terms:description "Disgust is a feeling of revulsion or profound disapproval aroused by something unpleasant or offensive."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "disgust"@en .


###  http://semanticscience.org/resource/SIO_000829
resource:SIO_000829 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000837 ;
                    dc:identifier "SIO_000829" ;
                    terms:description "dread is the instense negative emotion that induces fear and apprehension."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "dread"@en .


###  http://semanticscience.org/resource/SIO_000830
resource:SIO_000830 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000831 ;
                    dc:identifier "SIO_000830" ;
                    terms:description "ecstacy is an emotion characterized by a heightened state of consciousness with total involvement of a subject."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "ecstasy"@en .


###  http://semanticscience.org/resource/SIO_000831
resource:SIO_000831 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000276 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000217 ;
                                      owl:someValuesFrom resource:SIO_001210
                                    ] ;
                    dc:identifier "SIO_000831" ;
                    terms:description "A positive emotion is an emotion that feels good."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "positive emotion"@en .


###  http://semanticscience.org/resource/SIO_000832
resource:SIO_000832 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000276 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000217 ;
                                      owl:someValuesFrom resource:SIO_001211
                                    ] ;
                    dc:identifier "SIO_000832" ;
                    terms:description "negative emotion is an emotion that does not feel good."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "negative emotion"@en .


###  http://semanticscience.org/resource/SIO_000833
resource:SIO_000833 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000833" ;
                    terms:description "Embarrassment is the emotion of intense discomfort with oneself, experienced upon having a socially unacceptable act or condition witnessed by or revealed to other."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "embarassment"@en .


###  http://semanticscience.org/resource/SIO_000834
resource:SIO_000834 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000834" ;
                    terms:description "envy is an emotion that occurs when a person lacks another's (perceived) superior quality, achievement or possession and wishes that the other lacked it."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "envy"@en .


###  http://semanticscience.org/resource/SIO_000835
resource:SIO_000835 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000840 ;
                    dc:identifier "SIO_000835" ;
                    terms:description "euphoria is an emotion characterized by intense feelings of well-being, elation, happiness, ecstasy, excitement, and joy."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "euphoria"@en .


###  http://semanticscience.org/resource/SIO_000836
resource:SIO_000836 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000831 ;
                    dc:identifier "SIO_000836" ;
                    terms:description "excitement is a positive emotion of feeling great enthusiasm and eagerness."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "excitement"@en .


###  http://semanticscience.org/resource/SIO_000837
resource:SIO_000837 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000949 ;
                    dc:identifier "SIO_000837" ;
                    terms:description "Fear is a negative emotion induced by a perceived threat that induces one to hide or move quickly away from the location of the perceived threat."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "fear"@en .


###  http://semanticscience.org/resource/SIO_000838
resource:SIO_000838 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000814 ;
                    dc:identifier "SIO_000838" ;
                    terms:description "Frustration is an emotion that arises from the perceived resistance to the fulfillment of individual will. "@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "frustration"@en .


###  http://semanticscience.org/resource/SIO_000839
resource:SIO_000839 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000831 ;
                    dc:identifier "SIO_000839" ;
                    terms:alternative "appreciation" ,
                                      "gratefulness" ,
                                      "gratification" ,
                                      "thankfullness" ;
                    terms:description "Gratitude, thankfulness, gratefulness, or appreciation is a feeling, emotion or attitude in acknowledgment of a benefit that one has received or will receive."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "gratitude"@en .


###  http://semanticscience.org/resource/SIO_000840
resource:SIO_000840 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000831 ;
                    dc:identifier "SIO_000840" ;
                    terms:description "happiness is an emotion characterized by positive or pleasant emotions ranging from contentment to intense joy."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "happiness"@en .


###  http://semanticscience.org/resource/SIO_000841
resource:SIO_000841 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000841" ;
                    terms:alternative "guilty" ;
                    terms:description "Guilt is the emotion borne from feeling responsible for the commission of an offense and arises out of public humiliation."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "guilt"@en .


###  http://semanticscience.org/resource/SIO_000842
resource:SIO_000842 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000863 ;
                    dc:identifier "SIO_000842" ;
                    terms:description "grief is an emotion in response to loss, whether physical or abstract including death, unemployment, ill health or the end of a relationship."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "grief"@en .


###  http://semanticscience.org/resource/SIO_000843
resource:SIO_000843 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000831 ;
                    dc:identifier "SIO_000843" ;
                    terms:description "hope is an emotion of belief in a positive outcome related to events and circumstances in one's life."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "hope"@en .


###  http://semanticscience.org/resource/SIO_000844
resource:SIO_000844 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000844" ;
                    terms:description "Hostility is the intense negative emotion of being in conflict or opposition to someone or something."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "hostility"@en .


###  http://semanticscience.org/resource/SIO_000845
resource:SIO_000845 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000845" ;
                    terms:description "hurt is an unpleasant feeling, emotion or sensation."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "hurt"@en .


###  http://semanticscience.org/resource/SIO_000846
resource:SIO_000846 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000846" ;
                    terms:description "Hysteria is an unmanageable emotion."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "hysteria"@en .


###  http://semanticscience.org/resource/SIO_000847
resource:SIO_000847 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000276 ,
                                    [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                             owl:complementOf [ rdf:type owl:Restriction ;

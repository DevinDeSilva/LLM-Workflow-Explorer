                    rdfs:subClassOf resource:SIO_000678 ;
                    dc:identifier "SIO_000721" ;
                    terms:description "A comparative role is an abstract role which holds by comparing some attribute of another object of reference."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;

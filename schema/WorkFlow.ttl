                    rdfs:subClassOf resource:SIO_000569 ;
                    dc:identifier "SIO_000568" ;
                    terms:description "A partial differential equation (PDE) is a differential equation in which the unknown function is a function of multiple independent variables and the equation involves its partial derivatives."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "partial differential equation"@en .


###  http://semanticscience.org/resource/SIO_000569

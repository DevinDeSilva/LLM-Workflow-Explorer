terms:description rdf:type owl:AnnotationProperty ;
                  dc:identifier "description" .


###  http://purl.org/dc/terms/issued
terms:issued rdf:type owl:AnnotationProperty ;
             dc:identifier "issued" .


###  http://purl.org/dc/terms/license
terms:license rdf:type owl:AnnotationProperty ;
              dc:identifier "license" .


###  http://purl.org/dc/terms/modified
terms:modified rdf:type owl:AnnotationProperty ;
               dc:identifier "modified" .


###  http://purl.org/dc/terms/rights
terms:rights rdf:type owl:AnnotationProperty ;
             dc:identifier "rights" .


###  http://purl.org/dc/terms/source
terms:source rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
terms:title rdf:type owl:AnnotationProperty ;
            dc:identifier "title" .


###  http://purl.org/spar/cito/citesAsAuthority
cito:citesAsAuthority rdf:type owl:AnnotationProperty ;
                      dc:identifier "citesAsAuthority" .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty ;
                              dc:identifier "preferredNamespacePrefix" .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty ;
                           dc:identifier "preferredNamespaceUri" .



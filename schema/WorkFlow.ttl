                    rdfs:subClassOf resource:SIO_001427 ;
                    dc:identifier "SIO_001425" ;
                    terms:description "a peptide is an organic polymer composed of between two and fifty amino acids."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "peptide"@en .



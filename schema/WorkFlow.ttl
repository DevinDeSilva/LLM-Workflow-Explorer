                                                                                     ]
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty <http://linkedu.eu/dedalo/explanationPattern.owl#isBasedOn> ;
                                                                                       owl:someValuesFrom [ owl:intersectionOf ( <https://purl.org/heals/eo#object_record>
                                                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                                                   owl:onProperty prov:wasGeneratedBy ;
                                                                                                                                   owl:someValuesFrom [ owl:intersectionOf ( <https://purl.org/heals/eo#AITask>
                                                                                                                                                                             [ rdf:type owl:Restriction ;
                                                                                                                                                                               owl:onProperty prov:used ;
                                                                                                                                                                               owl:someValuesFrom [ owl:intersectionOf ( <https://purl.org/heals/eo#ArtificialIntelligenceMethod>
                                                                                                                                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                                                                                                                                           owl:onProperty resource:SIO_000230 ;
                                                                                                                                                                                                                           owl:someValuesFrom <https://purl.org/heals/eo#object_record>
                                                                                                                                                                                                                         ]
                                                                                                                                                                                                                       ) ;
                                                                                                                                                                                                    rdf:type owl:Class
                                                                                                                                                                                                  ]
                                                                                                                                                                             ]
                                                                                                                                                                           ) ;
                                                                                                                                                        rdf:type owl:Class
                                                                                                                                                      ]
                                                                                                                                 ]
                                                                                                                               ) ;

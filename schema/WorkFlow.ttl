###  http://semanticscience.org/resource/SIO_000190
resource:SIO_000190 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000190" ;
                    terms:description "An author contribution section is a document section that describes the contribution of the authors."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "author contribution section"@en .


###  http://semanticscience.org/resource/SIO_000191
resource:SIO_000191 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000191" ;
                    terms:description "An author section is a document section that lists the contributing authors."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "author section"@en .


###  http://semanticscience.org/resource/SIO_000192
resource:SIO_000192 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000192" ;
                    terms:description "A bibliography section is a document section that is composed of a list of references used in the development of the work."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "bibliography section"@en .


###  http://semanticscience.org/resource/SIO_000193
resource:SIO_000193 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000193" ;
                    terms:description "A copyright section is a document section that contains a notice of copyright."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "copyright section"@en .


###  http://semanticscience.org/resource/SIO_000194
resource:SIO_000194 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000194" ;
                    terms:description "A correspondence section is a document section that contains the details for contacting the corresponding author."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "correspondence section"@en .


###  http://semanticscience.org/resource/SIO_000195
resource:SIO_000195 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000195" ;
                    terms:description "The discussion section is a document section containing a summary of the findings, a reflection on the significance of findings, comparison with related work, among others."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "discussion section"@en .


###  http://semanticscience.org/resource/SIO_000196
resource:SIO_000196 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000196" ;
                    terms:description "An introduction section is a document section that generally provides background, motivation and goals of the work."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "introduction section"@en .


###  http://semanticscience.org/resource/SIO_000197
resource:SIO_000197 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000197" ;
                    terms:description "The materials and methods section is a document section containing a description of the materials and methods used in the study."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "materials and methods section"@en .


###  http://semanticscience.org/resource/SIO_000198
resource:SIO_000198 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000198" ;
                    terms:description "The materials section is a document section containing a description of the materials used in the study."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "materials section"@en .


###  http://semanticscience.org/resource/SIO_000199
resource:SIO_000199 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000199" ;
                    terms:description "The methods section is a document section containing a description of the methods used in the study."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "methods section"@en .


###  http://semanticscience.org/resource/SIO_000200
resource:SIO_000200 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000200" ;
                    terms:description "The results section is a document section describing the main findings of the study."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "results section"@en .


###  http://semanticscience.org/resource/SIO_000201
resource:SIO_000201 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000201" ;
                    terms:description "The table of contents is a document section that lists all sections (and optionally subsections) in a sequential order along with their page number."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "table of contents"@en .


###  http://semanticscience.org/resource/SIO_000220
resource:SIO_000220 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000238 ;
                    dc:identifier "SIO_000220" ;
                    terms:description "Implication is a logical operator that holds between a set T of propositions and a proposition B, when every model (or interpretation or valuation) of T is also a model of B."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "implies (->)"@en .


###  http://semanticscience.org/resource/SIO_000237
resource:SIO_000237 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000179 ;
                    dc:identifier "SIO_000237" ;
                    terms:description "A namespace label is a short name for a namespace."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "namespace label"@en .


###  http://semanticscience.org/resource/SIO_000238
resource:SIO_000238 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000075 ;
                    dc:identifier "SIO_000238" ;
                    terms:description "A logical operator is a unary or binary relation to construct logical expressions."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "logical operator"@en .


###  http://semanticscience.org/resource/SIO_000239
resource:SIO_000239 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000238 ;
                    dc:identifier "SIO_000239" ;
                    terms:description "AND is a logical operator that has the value true if both of its operands are true, otherwise a value of false."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "conjunction (and)"@en .


###  http://semanticscience.org/resource/SIO_000256
resource:SIO_000256 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000136 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000217 ;
                                      owl:someValuesFrom resource:SIO_000268
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000332 ;
                                      owl:someValuesFrom resource:SIO_000000
                                    ] ;
                    dc:identifier "SIO_000256" ;
                    terms:description "A proposition is a sentence expressing something true or false."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "proposition"@en .


###  http://semanticscience.org/resource/SIO_000257
resource:SIO_000257 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000052 ,
                                    [ rdf:type owl:Class ;
                                      owl:complementOf [ rdf:type owl:Restriction ;
                                                         owl:onProperty resource:SIO_000221 ;
                                                         owl:someValuesFrom resource:SIO_000074
                                                       ]
                                    ] ;
                    owl:disjointWith resource:SIO_000258 ;
                    dc:identifier "SIO_000257" ;
                    terms:description "A dimensionless quantity is a quantity that has no associated unit."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "dimensionless quantity"@en .


###  http://semanticscience.org/resource/SIO_000258
resource:SIO_000258 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000052 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000221 ;
                                      owl:someValuesFrom resource:SIO_000074
                                    ] ;
                    dc:identifier "SIO_000258" ;
                    terms:description "A dimensional quantity is a quantity that has an associated unit."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "dimensional quantity"@en .


###  http://semanticscience.org/resource/SIO_000259
resource:SIO_000259 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000256 ,
                                    [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                             owl:onProperty resource:SIO_000053 ;
                                                             owl:someValuesFrom resource:SIO_000261
                                                           ]
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty resource:SIO_000053 ;
                                                             owl:someValuesFrom resource:SIO_000262
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                    dc:identifier "SIO_000259" ;
                    terms:description "An argument is a set of one or more declarative sentences (or propositions) known as the premises along with another declarative sentence (or proposition) known as the conclusion."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "argument"@en .


###  http://semanticscience.org/resource/SIO_000261
resource:SIO_000261 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000256 ;
                    dc:identifier "SIO_000261" ;
                    terms:description "A premise is a proposition of an argument from which the conclusion is drawn."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "premise"@en .


###  http://semanticscience.org/resource/SIO_000262
resource:SIO_000262 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000256 ;
                    dc:identifier "SIO_000262" ;
                    terms:description "A conclusion is a proposition which is reached after considering the evidence, arguments or premises."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "conclusion"@en .


###  http://semanticscience.org/resource/SIO_000263
resource:SIO_000263 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000259 ;
                    dc:identifier "SIO_000263" ;
                    terms:description "A deductive argument is an argument that asserts that the truth of the conclusion is a logical consequence of the premises."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "deductive argument"@en .


###  http://semanticscience.org/resource/SIO_000264
resource:SIO_000264 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000259 ;
                    dc:identifier "SIO_000264" ;
                    terms:description "An inductive argument is an argument that asserts that the truth of the conclusion is supported by the premises."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "inductive argument"@en .


###  http://semanticscience.org/resource/SIO_000265
resource:SIO_000265 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000266 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000053 ;
                                      owl:someValuesFrom [ owl:intersectionOf ( resource:SIO_000261
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty resource:SIO_000217 ;
                                                                                  owl:someValuesFrom resource:SIO_000269
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ]
                                    ] ;
                    dc:identifier "SIO_000265" ;
                    terms:description "A sound argument is a valid argument with true premises."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "sound argument"@en .


###  http://semanticscience.org/resource/SIO_000266
resource:SIO_000266 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000259 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000053 ;
                                      owl:someValuesFrom [ owl:intersectionOf ( resource:SIO_000262
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty resource:SIO_000217 ;
                                                                                  owl:someValuesFrom resource:SIO_000270
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ]
                                    ] ;
                    dc:identifier "SIO_000266" ;
                    terms:description "A valid argument is an argument where the truth of the conclusion is a logical consequence of the premises and (consequently) its corresponding conditional is a necessary truth."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "valid argument"@en .


###  http://semanticscience.org/resource/SIO_000267
resource:SIO_000267 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000259 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000053 ;
                                      owl:someValuesFrom [ owl:intersectionOf ( resource:SIO_000262
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty resource:SIO_000217 ;
                                                                                  owl:someValuesFrom resource:SIO_000270
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ]
                                    ] ;
                    dc:identifier "SIO_000267" ;
                    terms:description "An invalid argument is an argument where the truth of the conclusion is false because it is not a logical consequence of the premises."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "invalid argument"@en .



                                                                                owl:someValuesFrom resource:SIO_001211
                                                                              ]
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                    dc:identifier "SIO_000847" ;
                    terms:description "indifference is an emotion characterized by lack of interest, concern, or sympathy."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "indifference"@en .


###  http://semanticscience.org/resource/SIO_000848
resource:SIO_000848 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000831 ;
                    dc:identifier "SIO_000848" ;
                    terms:description "interest is the emotion of wanting to know or learn about something or someone."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "interest"@en .


###  http://semanticscience.org/resource/SIO_000849
resource:SIO_000849 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000834 ;
                    dc:identifier "SIO_000849" ;
                    terms:description "jealousy is an emotion and typically refers to the negative thoughts and feelings of insecurity, fear, and anxiety over an anticipated loss of something that the person values, particularly in reference to a human connection."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "jealousy"@en .


###  http://semanticscience.org/resource/SIO_000850
resource:SIO_000850 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000840 ;
                    dc:identifier "SIO_000850" ;
                    terms:description "joy is an emotion of intense happiness."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "joy"@en .


###  http://semanticscience.org/resource/SIO_000851
resource:SIO_000851 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000828 ;
                    dc:identifier "SIO_000851" ;
                    terms:description "loathing is an intense dislike or disgust."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "loathing"@en .


###  http://semanticscience.org/resource/SIO_000852
resource:SIO_000852 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000852" ;
                    terms:description "Loneliness is an unpleasant emotion in which a person feels a strong sense of emptiness, yearning distress and solitude resulting from inadequate quantity or quality of social relationships."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "loneliness"@en .


###  http://semanticscience.org/resource/SIO_000853
resource:SIO_000853 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000825 ;
                    dc:identifier "SIO_000853" ;
                    terms:description "lust is the strong desire for sex."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "lust"@en .


###  http://semanticscience.org/resource/SIO_000854
resource:SIO_000854 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000863 ;
                    dc:identifier "SIO_000854" ;
                    terms:description "misery is a feeling of great unhappiness, suffering and/or pain."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "misery"@en .


###  http://semanticscience.org/resource/SIO_000855
resource:SIO_000855 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000837 ;
                    dc:identifier "SIO_000855" ;
                    terms:description "Panic is a sudden emotion of fear which is so strong as to dominate or prevent reason and logical thinking, replacing it with overwhelming feelings of anxiety and frantic agitation consistent with an animalistic fight-or-flight reaction."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "panic"@en .


###  http://semanticscience.org/resource/SIO_000856
resource:SIO_000856 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000825 ;
                    dc:identifier "SIO_000856" ;
                    terms:description "passion is the intense desire for something."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "passion"@en .


###  http://semanticscience.org/resource/SIO_000857
resource:SIO_000857 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000857" ;
                    terms:description "Pity is the emotion of sadness or sorrow for another."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "pity"@en .


###  http://semanticscience.org/resource/SIO_000858
resource:SIO_000858 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000840 ;
                    dc:identifier "SIO_000858" ;
                    terms:description "pleasure is an emotion of happy satisfaction and enjoyment."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "pleasure"@en .


###  http://semanticscience.org/resource/SIO_000859
resource:SIO_000859 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000864 ;
                    dc:identifier "SIO_000859" ;
                    terms:description "pride is an emotion of satisfaction of attachment toward one's own or another's choices and actions, or toward a whole group of people, and is a product of praise, independent self-reflection, or a fulfilled feeling of belonging."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "pride"@en .


###  http://semanticscience.org/resource/SIO_000860
resource:SIO_000860 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000410 ;
                    dc:identifier "SIO_000860" ;
                    terms:description "Rage is a feeling of intense anger that is associated with the Fight-or-flight response."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "rage"@en .


###  http://semanticscience.org/resource/SIO_000861
resource:SIO_000861 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000873 ;
                    dc:identifier "SIO_000861" ;
                    terms:description "regret is a feeling of sadness, repentance, or disappointment over something that has happened or been done."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "regret"@en .


###  http://semanticscience.org/resource/SIO_000862
resource:SIO_000862 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000861 ;
                    dc:identifier "SIO_000862" ;
                    terms:description "remorse is an emotion of personal regret felt by a person after he or she has committed an act which they deem to be shameful, hurtful, or violent."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "remorse"@en .


###  http://semanticscience.org/resource/SIO_000863
resource:SIO_000863 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000863" ;
                    terms:alternative "sad" ,
                                      "unhappiness" ,
                                      "unhappy" ;
                    terms:description "sadness is emotional pain associated with, or characterized by feelings of disadvantage, loss, despair, helplessness, sorrow, and rage."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "sadness"@en .


###  http://semanticscience.org/resource/SIO_000864
resource:SIO_000864 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000822 ;
                    dc:identifier "SIO_000864" ;
                    terms:description "satisfaction is an emotion of fulfillment of one's wishes, expectations, or needs, or the pleasure derived from this."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "satisfaction"@en .


###  http://semanticscience.org/resource/SIO_000865
resource:SIO_000865 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000865" ;
                    terms:description "shame is the emotion borne from feeling responsible for the commission of an offense."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "shame"@en .


###  http://semanticscience.org/resource/SIO_000866
resource:SIO_000866 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000866" ;
                    terms:description "shock is an emotion of sudden upset or surprise."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "shock"@en .


###  http://semanticscience.org/resource/SIO_000867
resource:SIO_000867 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000832 ;
                    dc:identifier "SIO_000867" ;
                    terms:description "shyness is an emotion of apprehension, lack of comfort, or awkwardness experienced when in proximity to, approaching, or being approached by other individuals, especially in new situations or with unfamiliar individuals."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "shyness"@en .


###  http://semanticscience.org/resource/SIO_000868
resource:SIO_000868 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000863 ;
                    dc:identifier "SIO_000868" ;
                    terms:description "sorrow is the emotion that is characterized by a long term state of intense sadness, distress and a degree of resignation (not accepting)."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "sorrow"@en .


###  http://semanticscience.org/resource/SIO_000869
resource:SIO_000869 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000845 ;
                    dc:identifier "SIO_000869" ;
                    terms:description "Suffering is the unpleasant emotion and aversion associated with the perception of harm or threat of harm in an individual."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "suffering"@en .


###  http://semanticscience.org/resource/SIO_000870
resource:SIO_000870 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000831 ;
                    dc:identifier "SIO_000870" ;
                    terms:description "surprise is a brief emotion experienced as the result of an unexpected event. "@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "surprise"@en .


###  http://semanticscience.org/resource/SIO_000871
resource:SIO_000871 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000829 ;
                    dc:identifier "SIO_000871" ;
                    terms:description "terror is the extreme feeling of fear."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "terror"@en .


###  http://semanticscience.org/resource/SIO_000872
resource:SIO_000872 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000870 ;
                    dc:identifier "SIO_000872" ;
                    terms:description "wonder is an emotion of perceiving something very rare or unexpected, but not threatening."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "wonder"@en .


###  http://semanticscience.org/resource/SIO_000873
resource:SIO_000873 rdf:type owl:Class ;

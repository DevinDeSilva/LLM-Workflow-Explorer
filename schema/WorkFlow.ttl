###  http://semanticscience.org/resource/SIO_001441
resource:SIO_001441 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001443 ;
                    owl:disjointWith resource:SIO_001442 ;
                    dc:identifier "SIO_001441" ;
                    terms:description "An imaginary number is a complex number whose real part is zero e.g. 0 + bi, and is expressed as a multiple of the square root of -1."@en ;
                    resource:example "5i is an imaginary number, and its square is -25."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "imaginary number"@en .


###  http://semanticscience.org/resource/SIO_001442
resource:SIO_001442 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001443 ;
                    dc:identifier "SIO_001442" ;
                    terms:description "a real number is a complex number whose imaginary part is zero, e.g. a + 0i."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "real number"@en .


###  http://semanticscience.org/resource/SIO_001443
resource:SIO_001443 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000366 ,
                                    [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                             owl:onProperty resource:SIO_000369 ;
                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                             owl:onClass resource:SIO_001441
                                                           ]
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty resource:SIO_000369 ;
                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                             owl:onClass resource:SIO_001442
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                    dc:identifier "SIO_001443" ;
                    terms:description "a complex number is an element of a number system that extends the real numbers with an imaginary unit i. Every complex number can be expressed in the form a + bi, where a and b are real numbers."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "complex number"@en .


###  http://semanticscience.org/resource/SIO_001444

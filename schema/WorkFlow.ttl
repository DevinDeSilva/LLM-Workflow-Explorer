                                                 rdfs:isDefinedBy "Marsha A. Schubert" ,
                                                                  "Thomasina J. Borkman" ;
                                                 rdfs:label "Experential Knowledge" ;
                                                 skos:definition "information and wisdom gained from lived experience" .



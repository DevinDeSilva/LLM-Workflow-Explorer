                    rdfs:subClassOf resource:SIO_000963 ;
                    dc:identifier "SIO_000996" ;
                    terms:description "cancelled is a process status in which the process, while planned to occur, will not occur."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "cancelled"@en .


###  http://semanticscience.org/resource/SIO_000997
resource:SIO_000997 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000033 ;
                    dc:identifier "SIO_000997" ;
                    terms:description "aborted is a process status in which a started process will not complete as intended."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;

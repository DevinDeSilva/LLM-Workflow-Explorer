                                      owl:onProperty resource:SIO_000218 ;
                                      owl:someValuesFrom resource:SIO_000651
                                    ] ;
                    dc:identifier "SIO_001033" ;
                    terms:description "text quality is the quality of a textual entity."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "text quality"@en .


###  http://semanticscience.org/resource/SIO_001034
resource:SIO_001034 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001039 ;
                    dc:identifier "SIO_001034" ;
                    terms:description "reviewed is the quality of a textual entity that has been examined and commented on by another party."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;

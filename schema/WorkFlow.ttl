                                 dc:description "facts that would have led to a system recommendation that could have occured" ;
                                 rdfs:isDefinedBy "Daniel Gruen" ;
                                 rdfs:label "Foil" .


###  https://purl.org/heals/eo#GlobalExplanationOutput
<https://purl.org/heals/eo#GlobalExplanationOutput> rdf:type owl:Class ;

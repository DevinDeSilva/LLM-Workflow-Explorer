                    rdfs:subClassOf resource:SIO_010375 ;
                    dc:identifier "SIO_000486" ;
                    terms:description "A mouse is a small mammal belonging to the order of rodents, characteristically having a pointed snout, small rounded ears, and a long naked or almost hairless tail. "@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "mouse"@en .



                                                                                                                         owl:someValuesFrom resource:SIO_001066
                                                                                                                       ]
                                                                                                                     ) ;
                                                                                                  rdf:type owl:Class
                                                                                                ]
                                                                           ] ;
                                                       rdfs:subClassOf <https://purl.org/heals/eo#scientificExplanation> ;
                                                       dc:description "account that articulates how or why an event occured that is supported by evidence and scientific ideas" ;
                                                       terms:modified "Shruthi Chari" ;
                                                       terms:source "https://www.sciencepracticesleadership.com/definitions.html" ;
                                                       rdfs:label "Evidence Based Explanation" ;
                                                       skos:example "Address questions of the form, \"What studies support this recommendation?\"" .


###  https://purl.org/heals/eo#ExemplarMethods
<https://purl.org/heals/eo#ExemplarMethods> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://purl.org/heals/eo#ExplanationMethod> ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty resource:SIO_000229 ;
                                                              owl:someValuesFrom <https://purl.org/heals/eo#LocalExplanation>
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty resource:SIO_000229 ;
                                                              owl:someValuesFrom <https://purl.org/heals/eo#StaticExplanation>
                                                            ] ;
                                            terms:description "This category explains the predictions of test instances using similar or influential training instances. It is considered as static local post-hoc explanations with samples." ;
                                            terms:source "Arya, V., Bellamy, R. K., Chen, P. Y., Dhurandhar, A., Hind, M., Hoffman, S. C., ... & Zhang, Y. (2019). One explanation does not fit all: A toolkit and taxonomy of ai explainability techniques. arXiv preprint arXiv:1909.03012." ;
                                            rdfs:label "Exemplar Method" .


###  https://purl.org/heals/eo#ExperentialKnowledge

###  http://semanticscience.org/resource/SIO_000000
resource:SIO_000000 rdf:type owl:Class ;
                    dc:identifier "SIO_000000" ;
                    terms:description "Every thing is an entity."@en ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "entity"@en .


###  http://semanticscience.org/resource/SIO_000004
resource:SIO_000004 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000776 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000008 ;
                                      owl:someValuesFrom resource:SIO_000279
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000053 ;
                                      owl:allValuesFrom [ rdf:type owl:Class ;
                                                          owl:unionOf ( resource:SIO_000004
                                                                        resource:SIO_000370
                                                                      )
                                                        ]
                                    ] ;
                    dc:identifier "SIO_000004" ;
                    terms:description "A material entity is a physical entity that is spatially extended, exists as a whole at any point in time and has mass."@en ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "material entity"@en .


###  http://semanticscience.org/resource/SIO_000005
resource:SIO_000005 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000614 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000218 ;
                                      owl:someValuesFrom resource:SIO_000000
                                    ] ;
                    owl:disjointWith resource:SIO_000340 ;
                    dc:identifier "SIO_000005" ;
                    terms:description "A quality is an attribute that is intrinsically associated with its bearer (or its parts), but whose presence/absence and observed/measured value may vary."@en ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "quality"@en .


###  http://semanticscience.org/resource/SIO_000006
resource:SIO_000006 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000000 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000053 ;
                                      owl:allValuesFrom resource:SIO_000006
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000687 ;
                                      owl:allValuesFrom resource:SIO_000417
                                    ] ;
                    dc:identifier "SIO_000006" ;
                    terms:description "A process is an entity that is identifiable only through the unfolding of time, has temporal parts, and unless otherwise specified/predicted, cannot be identified from any instant of time in which it exists."@en ;
                    resource:subset "core" ,
                                    "process+" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "process"@en .


###  http://semanticscience.org/resource/SIO_000009
resource:SIO_000009 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000015 ;
                    dc:identifier "SIO_000009" ;
                    terms:description "A social entity pertains to the interaction among individuals and groups."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "social entity"@en .


###  http://semanticscience.org/resource/SIO_000010
resource:SIO_000010 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000009 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000059 ;
                                      owl:allValuesFrom resource:SIO_000776
                                    ] ;
                    dc:identifier "SIO_000010" ;
                    terms:description "A social structure is a social entity which consists of relationships between two or more entities."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "social structure"@en .


###  http://semanticscience.org/resource/SIO_000012
resource:SIO_000012 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000620 ;
                    dc:identifier "SIO_000012" ;
                    terms:description "An organization is a collective with a complex articulation of tasks, roles and responsibilities."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "organization"@en .


###  http://semanticscience.org/resource/SIO_000013
resource:SIO_000013 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000056 ;
                    dc:identifier "SIO_000013" ;
                    terms:description "A geographic position is the coordinate of an entity against some geographic coordinate system."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "geographic position"@en .


###  http://semanticscience.org/resource/SIO_000014
resource:SIO_000014 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000112 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000008 ;
                                      owl:someValuesFrom resource:SIO_000638
                                    ] ;
                    dc:identifier "SIO_000014" ;
                    terms:description "A disposition is the tendency of a capability to be exhibited under certain conditions or in response to a certain stimulus (trigger)."@en ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "disposition"@en ;
                    skos:example "solubility (to dissolve when put in fluid); fragility (disposition to break when dropped)"@en .


###  http://semanticscience.org/resource/SIO_000015
resource:SIO_000015 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000776 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000053 ;
                                      owl:allValuesFrom resource:SIO_000015
                                    ] ;
                    dc:identifier "SIO_000015" ;
                    terms:description "information content entity is an object that requires some background knowledge or procedure to correctly interpret."@en ;
                    resource:subset "core" ,
                                    "ice+" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "information content entity"@en .


###  http://semanticscience.org/resource/SIO_000016
resource:SIO_000016 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000340 ;
                    dc:identifier "SIO_000016" ;
                    terms:description "A role is a realizable entity that describes behaviours, rights and obligations of an entity in some particular circumstance."@en ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "role"@en .


###  http://semanticscience.org/resource/SIO_000017
resource:SIO_000017 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000112 ;
                    owl:disjointWith resource:SIO_000354 ;
                    dc:identifier "SIO_000017" ;
                    terms:description "A function is a capability that satisfies some agentive objective, or (evolutionary) optimization."@en ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "function"@en .


###  http://semanticscience.org/resource/SIO_000019
resource:SIO_000019 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000370 ;
                    dc:identifier "SIO_000019" ;
                    terms:description "A site is a spatial region bounded (in part or in whole) by material entities and may be occupied by material entities."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "site"@en ;
                    skos:example "A nostril; the interior of the heart valve; the interior of a bottle."@en .


###  http://semanticscience.org/resource/SIO_000022
resource:SIO_000022 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000783 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000096 ;
                                      owl:someValuesFrom resource:SIO_000004
                                    ] ;
                    dc:identifier "SIO_000022" ;
                    terms:description "A material boundary is the boundary of a material entity which exists as a lower dimensional entity at exactly the location where its parts no longer extend into space. Every material entity has a boundary, and a boundary is the boundary of exactly 1 material entity."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "material boundary"@en ;
                    skos:example "the external surface of the window; the surface of the p52 protein"@en .


###  http://semanticscience.org/resource/SIO_000026
resource:SIO_000026 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000005 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000218 ;
                                      owl:someValuesFrom resource:SIO_000776
                                    ] ;
                    dc:identifier "SIO_000026" ;
                    terms:description "An object quality is quality of an object."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "object quality"@en .


###  http://semanticscience.org/resource/SIO_000027
resource:SIO_000027 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000005 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000218 ;
                                      owl:someValuesFrom resource:SIO_000006
                                    ] ;
                    dc:identifier "SIO_000027" ;
                    terms:description "A process quality is quality that is associated with a process."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "process quality"@en .


###  http://semanticscience.org/resource/SIO_000030
resource:SIO_000030 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010014 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000210 ;
                                      owl:someValuesFrom [ owl:intersectionOf ( resource:SIO_000626
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty resource:SIO_000011 ;
                                                                                  owl:someValuesFrom resource:SIO_000092
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ]
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000563 ;
                                      owl:someValuesFrom resource:SIO_000092
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000300 ;
                                      owl:someValuesFrom xsd:string
                                    ] ;
                    dc:identifier "SIO_000030" ;
                    terms:description "A sequence is a primary structure descriptor in which each of the letters in the string represents a monomeric unit (residue) in which adjacent letters represent the connectivity between the monomeric units."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "biopolymer sequence"@en .


###  http://semanticscience.org/resource/SIO_000031
resource:SIO_000031 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000418 ;
                    dc:identifier "SIO_000031" ;
                    terms:description "A start date is a time instant pertaining to the date of the beginning of a process."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "start date"@en .


###  http://semanticscience.org/resource/SIO_000032
resource:SIO_000032 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000418 ;
                    dc:identifier "SIO_000032" ;
                    terms:description "An end date is a time instant pertaining to date of the end of a process."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "end date"@en .


###  http://semanticscience.org/resource/SIO_000033
resource:SIO_000033 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000027 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000011 ;
                                      owl:someValuesFrom resource:SIO_000006
                                    ] ;
                    dc:identifier "SIO_000033" ;
                    terms:description "process status is a process quality that describes the state of a process."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "process status"@en .


###  http://semanticscience.org/resource/SIO_000034
resource:SIO_000034 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000033 ;
                    dc:identifier "SIO_000034" ;
                    terms:description "completed is that status of a process that successfully unfolds."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "completed"@en .


###  http://semanticscience.org/resource/SIO_000035
resource:SIO_000035 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000033 ;
                    dc:identifier "SIO_000035" ;
                    terms:description "ongoing is the status of a process that is not yet complete."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "ongoing"@en .


###  http://semanticscience.org/resource/SIO_000036
resource:SIO_000036 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001186 ;
                    dc:identifier "SIO_000036" ;
                    terms:description "predicted is the quality of an entity that is thought to exist, as evidenced by some rational procedure."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "predicted"@en .


###  http://semanticscience.org/resource/SIO_000037
resource:SIO_000037 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000258 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000011 ;
                                      owl:someValuesFrom resource:SIO_000776
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000216 ;
                                      owl:someValuesFrom resource:SIO_000052
                                    ] ;
                    dc:identifier "SIO_000037" ;
                    terms:alternative "physical dimensional quantity"@en ;
                    terms:description "A spatial quantity is a quantity obtained from measuring the spatial extent of an entity "@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "spatial quantity"@en .


###  http://semanticscience.org/resource/SIO_000038
resource:SIO_000038 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000037 ;
                    dc:identifier "SIO_000038" ;
                    terms:description "A quantity that extends in single dimension."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "1D extent quantity"@en .


###  http://semanticscience.org/resource/SIO_000039
resource:SIO_000039 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000038 ;
                    dc:identifier "SIO_000039" ;
                    terms:description "depth is the dimensional extent into a plane of a 3D projection of the object."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "depth"@en .


###  http://semanticscience.org/resource/SIO_000040
resource:SIO_000040 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000038 ;
                    dc:identifier "SIO_000040" ;
                    terms:description "height is the one dimensional extent along the vertical projection of a 3D object from a base plane of reference."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "height"@en .


###  http://semanticscience.org/resource/SIO_000041
resource:SIO_000041 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000038 ;
                    dc:identifier "SIO_000041" ;
                    terms:description "length is the longer dimensional extent along a 2D projection of the object."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "length"@en .


###  http://semanticscience.org/resource/SIO_000042
resource:SIO_000042 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000038 ;
                    dc:identifier "SIO_000042" ;
                    terms:description "width is the shorter dimensional extent perpendicular to a 2D projection of the object."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "width"@en .


###  http://semanticscience.org/resource/SIO_000043
resource:SIO_000043 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000039 ;
                    dc:identifier "SIO_000043" ;
                    terms:description "thickness is the shortest dimensional extent of a 3D projection of an object."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "thickness"@en .


###  http://semanticscience.org/resource/SIO_000044
resource:SIO_000044 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000037 ;
                    dc:identifier "SIO_000044" ;
                    terms:description "A quantity that extends in two dimensions."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "2D extent quantity"@en .


###  http://semanticscience.org/resource/SIO_000045
resource:SIO_000045 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000044 ;
                    dc:identifier "SIO_000045" ;
                    terms:description "area is a quantity that pertains to the extent of a two-dimensional surface or shape, or planar lamina, in the plane."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "area"@en .


###  http://semanticscience.org/resource/SIO_000046
resource:SIO_000046 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000044 ;
                    dc:identifier "SIO_000046" ;
                    terms:description "A perimeter is a length of the outline that surrounds a two-dimensional shape. "@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "length of perimeter"@en .


###  http://semanticscience.org/resource/SIO_000047
resource:SIO_000047 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000046 ;
                    dc:identifier "SIO_000047" ;
                    terms:description "circumference is the length of the outline of a circle or ellipse. it is defined as c = 2*pi*r, where r is the radius."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "circumference"@en .


###  http://semanticscience.org/resource/SIO_000048
resource:SIO_000048 rdf:type owl:Class ;

                    rdfs:subClassOf resource:SIO_000578 ;
                    dc:identifier "SIO_000580" ;
                    terms:description "antiport enabled secondary active transport is a secondary active transfort in which both ion and molecule are transported in opposite directions simultaneously."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "antiport enabled secondary active transport"@en .



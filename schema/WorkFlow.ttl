                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000059 ;
                                      owl:allValuesFrom resource:SIO_010345
                                    ] ;
                    dc:identifier "SIO_010526" ;
                    terms:description "A chemical reaction pathway specifies a series of chemical reactions towards producing some chemical product."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "chemical reaction pathway"@en .


###  http://semanticscience.org/resource/SIO_010527
resource:SIO_010527 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010526 ;
                    dc:identifier "SIO_010527" ;
                    terms:description "A chemical synthesis pathway is a pathway involved in the assembly of a chemical."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "chemical synthesis pathway"@en .


###  http://semanticscience.org/resource/SIO_010528
resource:SIO_010528 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010526 ;
                    dc:identifier "SIO_010528" ;
                    terms:description "A chemical degradation pathway is a pathway involved in the disassembly of a chemical."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "chemical degradation pathway"@en .


###  http://semanticscience.org/resource/SIO_010530
resource:SIO_010530 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010023 ;
                    dc:identifier "SIO_010530" ;
                    terms:description "A 3D structure model is a representation of the spatial arrangement of one or more chemical entities."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "3d structure model"@en .


###  http://semanticscience.org/resource/SIO_010531
resource:SIO_010531 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000130 ;
                    dc:identifier "SIO_010531" ;
                    terms:description "A sequence profile is provides the preference for a character at each position of an abstracted sequence."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "sequence profile"@en .


###  http://semanticscience.org/resource/SIO_010532
resource:SIO_010532 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010525 ;
                    owl:disjointWith resource:SIO_010533 ;
                    dc:identifier "SIO_010532" ;
                    terms:description "A metabolic pathway is a series of biochemical reactions that begins with one or more substrates and ends with one or more products."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "metabolic pathway"@en .


###  http://semanticscience.org/resource/SIO_010533
resource:SIO_010533 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010525 ;
                    dc:identifier "SIO_010533" ;
                    terms:description "A regulatory pathway is a series of biochemical reactions that lead to the increase or decrease of activity of participating molecular components."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "regulatory pathway"@en .


###  http://semanticscience.org/resource/SIO_010673
resource:SIO_010673 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001196 ;
                    dc:identifier "SIO_010673" ;

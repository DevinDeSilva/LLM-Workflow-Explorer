###  http://semanticscience.org/resource/SIO_000316
resource:SIO_000316 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000315 ;
                    dc:identifier "SIO_000316" ;
                    terms:description "A design specification is a specification that provides precise and explicit information about the requirements for a product design."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "design specification"@en .


###  http://semanticscience.org/resource/SIO_000317
resource:SIO_000317 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000315 ;
                    dc:identifier "SIO_000317" ;
                    terms:description "A specification for spatial location is an effective specification towards representation spatial position or spatial data."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "spatial specification"@en .


###  http://semanticscience.org/resource/SIO_000318
resource:SIO_000318 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000013 ;
                    owl:disjointWith resource:SIO_000319 ;
                    dc:identifier "SIO_000318" ;
                    terms:description "Longitude is a geographic position that refers to  the angle east or west of a reference meridian between the two geographical poles to another meridian that passes through an arbitrary point."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "longitude"@en .


###  http://semanticscience.org/resource/SIO_000319
resource:SIO_000319 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000013 ;
                    dc:identifier "SIO_000319" ;
                    terms:description "Latitude is a geographic coordinate which refers to the angle from a point on the Earth's surface to the equatorial plane"@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "latitude"@en .


###  http://semanticscience.org/resource/SIO_000320
resource:SIO_000320 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000317 ;
                    dc:identifier "SIO_000320" ;
                    terms:description "A coordinate system is a specification for spatial location that uses a set of numbers, or coordinates, to uniquely determine the position of a point or other geometric element."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "coordinate system"@en .


###  http://semanticscience.org/resource/SIO_000321
resource:SIO_000321 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000320 ;
                    dc:identifier "SIO_000321" ;
                    terms:description "A Cartesian coordinate system specifies each point uniquely in a plane by a pair of numerical coordinates, which are the signed distances from the point to two fixed perpendicular directed lines, measured in the same unit of length."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "cartesian coordinate system"@en .


###  http://semanticscience.org/resource/SIO_000326
resource:SIO_000326 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000275 ;
                    dc:identifier "SIO_000326" ;
                    terms:description "A concept is term that refers to a generalization of a set of attributes or entities."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "concept"@en .


###  http://semanticscience.org/resource/SIO_000327
resource:SIO_000327 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000320 ;
                    dc:identifier "SIO_000327" ;
                    terms:description "A polar coordinate system is a two-dimensional coordinate system in which each point on a plane is determined by a distance from a fixed point and an angle from a fixed direction."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "polar coordinate system"@en .


###  http://semanticscience.org/resource/SIO_000328
resource:SIO_000328 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000115 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000011 ;
                                      owl:someValuesFrom resource:SIO_000056
                                    ] ;
                    dc:identifier "SIO_000328" ;
                    terms:description "A positional description is a description of location using some system or frame of reference."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "positional identifier"@en .


###  http://semanticscience.org/resource/SIO_000329
resource:SIO_000329 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000320 ;
                    dc:identifier "SIO_000329" ;
                    terms:description "A cylindrical coordinate system is a three-dimensional coordinate system that specifies point positions by the distance from a chosen reference axis, the direction from the axis relative to a chosen reference direction, and the distance from a chosen reference plane perpendicular to the axis."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "cylindrical coordinate system"@en .


###  http://semanticscience.org/resource/SIO_000330
resource:SIO_000330 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000320 ;
                    dc:identifier "SIO_000330" ;
                    terms:description "A spherical coordinate system is a coordinate system for three-dimensional space where the position of a point is specified by three numbers: the radial distance of that point from a fixed origin, its polar angle measured from a fixed zenith direction, and the azimuth angle of its orthogonal projection on a reference plane that passes through the origin and is orthogonal to the zenith, measured from a fixed reference direction on that plane."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "spherical coordinate system"@en .


###  http://semanticscience.org/resource/SIO_000331

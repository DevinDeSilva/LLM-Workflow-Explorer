                    rdfs:subClassOf resource:SIO_000367 ;
                    dc:identifier "SIO_000921" ;
                    terms:description "A dependent variable is one whose value changes as a consequence of changes in other values in the system."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "dependent variable"@en .



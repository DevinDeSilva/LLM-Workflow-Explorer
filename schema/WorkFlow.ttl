###  http://semanticscience.org/resource/SIO_000995
resource:SIO_000995 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000033 ;
                    dc:identifier "SIO_000995" ;
                    terms:description "suspended is the status of a process that is no longer progressing towards completion."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;

###  http://semanticscience.org/resource/SIO_000441
resource:SIO_000441 rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( resource:SIO_000507
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty resource:SIO_000369 ;
                                                                 owl:allValuesFrom resource:SIO_000402
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty resource:SIO_000369 ;
                                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                 owl:onClass resource:SIO_000402
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf resource:SIO_000507 ;
                    dc:identifier "SIO_000441" ;
                    terms:description "A 1D cartesian point is a point whose position is specified along a single dimension using Cartesian coordinates."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "1D cartesian point"@en .


###  http://semanticscience.org/resource/SIO_000442
resource:SIO_000442 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000083 ;
                    dc:identifier "SIO_000442" ;
                    terms:alternative "line chart"@en ;
                    terms:description "A line graph is a statistical graph in which lines contains the evaluation of functions or individual points connected by line segments."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "line graph"@en ;
                    skos:example "Graph 1 in http://tinyurl.com/opwnvm"@en .


###  http://semanticscience.org/resource/SIO_000443
resource:SIO_000443 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000083 ;
                    dc:identifier "SIO_000443" ;
                    terms:description "A bar graph is a statistical graph with rectangular bars of lengths proportional to that value that they represent."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "bar graph"@en ;
                    skos:example "Graphs 3,4,5 in http://tinyurl.com/opwnvm"@en .


###  http://semanticscience.org/resource/SIO_000444
resource:SIO_000444 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000443 ;
                    dc:identifier "SIO_000444" ;
                    terms:description "A horizontal bar graph is a bar graph in which the rectangular bars are horizontally oriented in space."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "horizontal bar graph"@en ;
                    skos:example "Graph 3 in http://tinyurl.com/opwnvm"@en .


###  http://semanticscience.org/resource/SIO_000445
resource:SIO_000445 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000443 ;
                    dc:identifier "SIO_000445" ;
                    terms:description "A vertical bar graph is a bar graph in which the rectangular bars are vertically oriented in space."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "vertical bar graph"@en ;
                    skos:example "Graph 4,5 in http://tinyurl.com/opwnvm"@en .


###  http://semanticscience.org/resource/SIO_000446
resource:SIO_000446 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000443 ;
                    dc:identifier "SIO_000446" ;
                    terms:description "A stacked bar graph is a bar graph in which each rectangular bar is partioned by the categorical value of each series of data."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "stacked bar graph"@en ;
                    skos:example "Graphs 6,7 in http://tinyurl.com/opwnvm"@en .


###  http://semanticscience.org/resource/SIO_000447
resource:SIO_000447 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000083 ;
                    dc:identifier "SIO_000447" ;
                    terms:description "A line-bar graph statistical graph that contains both lines and bars."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "line-bar graph"@en ;
                    skos:example "Graph 8 in http://tinyurl.com/opwnvm"@en .


###  http://semanticscience.org/resource/SIO_000448
resource:SIO_000448 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001194 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000093 ;
                                      owl:someValuesFrom resource:SIO_000080
                                    ] ;
                    dc:identifier "SIO_000448" ;
                    terms:description "A figure part is a part of a figure."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "figure part"@en .


###  http://semanticscience.org/resource/SIO_000449
resource:SIO_000449 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000448 ;
                    owl:disjointWith resource:SIO_000468 ;
                    dc:identifier "SIO_000449" ;
                    terms:description "A plot is a part of a figure that corresponds to the spatial region between the set of axes."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "plot"@en ;
                    skos:example """The square portion of the chart bounded by lines that overlap with 
the two axes in Graph 1 of http://tinyurl.com/opwnvm"""@en .


###  http://semanticscience.org/resource/SIO_000450
resource:SIO_000450 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000521 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000313 ;
                                      owl:someValuesFrom resource:SIO_000083
                                    ] ;
                    dc:identifier "SIO_000450" ;
                    terms:description """An axis is a line segment that is part of a statistical graph in which the 
position along the line corresponds to a numeric or categorical value."""@en ;
                    schema:comment "The value of a plotted geometric objects (e.g. point) can be obtained from the perpendicular projection of the position of the object onto the axis. Axis may also be associated with a textual description of what the values on the axis represents." ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "axis"@en ;
                    skos:example """The left vertical and bottom horizontal lines with tickmarks in 
Graph 1 http://tinyurl.com/opwnvm"""@en .


###  http://semanticscience.org/resource/SIO_000451
resource:SIO_000451 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000458 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000362 ;
                                      owl:someValuesFrom resource:SIO_000321
                                    ] ;
                    dc:identifier "SIO_000451" ;
                    terms:description "A Cartesian coordinate axis is an axis whose behavior follows that of a Cartesian coordinate system."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "Cartesian coordinate axis"@en .


###  http://semanticscience.org/resource/SIO_000452
resource:SIO_000452 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000451 ;
                    owl:disjointWith resource:SIO_000453 ,
                                     resource:SIO_000454 ;
                    dc:identifier "SIO_000452" ;
                    terms:alternative "horizontal axis" ;
                    terms:description "An x-axis is a Cartesian coordinate axis that is aligned with the horizon."@en ;
                    schema:comment "In most figures, this axis represents categories, such as months, market segments, or other non-numeric data."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "x-axis"@en ;
                    skos:example "The horizontal axis in http://tinyurl.com/opwnvm"@en .


###  http://semanticscience.org/resource/SIO_000453
resource:SIO_000453 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000451 ;
                    dc:identifier "SIO_000453" ;
                    terms:alternative "vertical axis" ;
                    terms:description "A y-axis is a Cartesian coordinate axis that is spatially oriented perpendicular to the x-axis."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "y-axis"@en .


###  http://semanticscience.org/resource/SIO_000454
resource:SIO_000454 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000451 ;
                    dc:identifier "SIO_000454" ;
                    terms:description "A z-axis is a Cartesian coordinate axis that is spatially oriented normal to the plane formed by the x- and y-axes."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "z-axis"@en .


###  http://semanticscience.org/resource/SIO_000455
resource:SIO_000455 rdf:type owl:Class ;
                    owl:equivalentClass [ rdf:type owl:Class ;
                                          owl:unionOf ( resource:SIO_000456
                                                        resource:SIO_000457
                                                      )
                                        ] ;
                    rdfs:subClassOf resource:SIO_000450 ;
                    owl:disjointWith resource:SIO_000458 ;
                    dc:identifier "SIO_000455" ;
                    terms:description "A category axis is an axis in which the position along the line is partioned into categories."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "category axis"@en ;
                    skos:example """The horizontal axis corresponding to months of the year in graph 4 
of http://tinyurl.com/opwnvm"""@en .


###  http://semanticscience.org/resource/SIO_000456
resource:SIO_000456 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000455 ;
                    owl:disjointWith resource:SIO_000457 ;
                    dc:identifier "SIO_000456" ;
                    terms:description "A primary category axis is a category axis that either defines the sole value range or holds the larger set of categorical values specified by the secondary category axis."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "primary category axis"@en ;
                    skos:example """The category axis that corresponds to years in Graph 1 of 
http://tinyurl.com/opwnvm"""@en .


###  http://semanticscience.org/resource/SIO_000457
resource:SIO_000457 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000455 ;
                    dc:identifier "SIO_000457" ;
                    terms:description "A secondary category axis is a category axis that defines a finer granular part (or subset) of the value range of the primary category axis."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "secondary category axis"@en ;
                    skos:example """The category axis that corresponds to months in Graph 1 of 
http://tinyurl.com/opwnvm"""@en .


###  http://semanticscience.org/resource/SIO_000458
resource:SIO_000458 rdf:type owl:Class ;
                    owl:equivalentClass [ rdf:type owl:Class ;
                                          owl:unionOf ( resource:SIO_000459
                                                        resource:SIO_000460
                                                        resource:SIO_000902
                                                        resource:SIO_000903
                                                      )
                                        ] ;
                    rdfs:subClassOf resource:SIO_000450 ;
                    dc:identifier "SIO_000458" ;
                    terms:description "A value axis is an axis in which the position along the line is partioned into numeric values."@en ;
                    schema:comment "A value axis holds the properties of having a minimum and a maximum value, and is usually associated with tickmarks that indicate intervals along the axis."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "value axis"@en ;
                    skos:example """The value axis that ranges from 3.0 to 7.4 and corresponds to 
billions of dollars in Graph 1 of http://tinyurl.com/opwnvm"""@en .


###  http://semanticscience.org/resource/SIO_000459
resource:SIO_000459 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000458 ;
                    dc:identifier "SIO_000459" ;
                    terms:description "A left value axis is a value axis that is spatially positioned to the left of the plot area."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "left value axis"@en ;
                    skos:example "The value axis that ranges from 3.0 to 7.4 and corresponds to billions of dollars in Graph 1 of http://tinyurl.com/opwnvm"@en .


###  http://semanticscience.org/resource/SIO_000460
resource:SIO_000460 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000458 ;
                    dc:identifier "SIO_000460" ;
                    terms:description "A right value axis is a value axis that is spatially positioned to the right of the plot area."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "right value axis"@en .


###  http://semanticscience.org/resource/SIO_000461
resource:SIO_000461 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000458 ;
                    dc:identifier "SIO_000461" ;
                    terms:description "A scaled value axis is a value axis in which the value range was subject to a mathematic transformation."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "scaled value axis"@en .


###  http://semanticscience.org/resource/SIO_000462
resource:SIO_000462 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000461 ;
                    owl:disjointWith resource:SIO_000463 ;
                    dc:identifier "SIO_000462" ;
                    terms:description "A linear value axis is a value axis that corresponds to a scaling factor of 1 of the value range."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "linear value axis"@en .


###  http://semanticscience.org/resource/SIO_000463
resource:SIO_000463 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000461 ;
                    dc:identifier "SIO_000463" ;
                    terms:description "A logarithmic value axis is a scaled value axis that corresponds to a scaling factor of the logarithm of the value range."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "logarithmic value axis"@en .


###  http://semanticscience.org/resource/SIO_000464
resource:SIO_000464 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000150 ;
                    dc:identifier "SIO_000464" ;
                    terms:description "A data series is a data set composed of related values displayed in a statistical graph."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "data series"@en ;
                    skos:example "Example: The two series that correspond to \"Seasonally adjusted\" and \"Trend\" are composed of the seasonally adjusted value of permits in each month and values from a trend derived from some mathematical tranformation across those values, respectively, in  Graph 1 of http://tinyurl.com/opwnvm"@en .



                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000369 ;
                                      owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                      owl:onClass resource:SIO_010044
                                    ] ;
                    dc:identifier "SIO_011118" ;
                    terms:description "A covalent bond is a strong submolecular interaction between atoms."@en ;

                    rdfs:subClassOf resource:SIO_001212 ;
                    dc:identifier "SIO_001213" ;
                    terms:description "mild is a qualitative intensity value that is more intense than weak, but less intense than moderate."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "mild"@en .



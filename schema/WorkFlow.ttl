                    rdfs:subClassOf resource:SIO_000570 ;
                    dc:identifier "SIO_000574" ;
                    terms:description "active movement is the process in which an object is spatially displaced using some chemical energy."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "active movement"@en .



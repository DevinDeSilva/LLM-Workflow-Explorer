                    rdfs:subClassOf resource:SIO_000904 ;
                    dc:identifier "SIO_000911" ;
                    terms:description "A histogram is a graphical representation of data which consists of tabular frequencies, shown as adjacent rectangles, over discrete intervals (bins) , with an area equal to the frequency of the observations in the interval."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "histogram"@en .



                    rdfs:subClassOf resource:SIO_001253 ,
                                    resource:SIO_001254 ;
                    dc:identifier "SIO_001249" ;
                    terms:description "A closed interval is an interval that includes its endpoints, and is denoted with square brackets."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "closed interval"@en ;
                    skos:example "[0,1] is a closed interval that is greater than or equal to 0 and less than or equal to 1."@en .



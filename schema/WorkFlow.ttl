###  http://semanticscience.org/resource/SIO_000181
resource:SIO_000181 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000116 ;
                    dc:identifier "SIO_000181" ;
                    terms:description "A first name is a name that denotes a specific individual between members of a group of individuals, whose members usually share the same surname."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "first name"@en .


###  http://semanticscience.org/resource/SIO_000182
resource:SIO_000182 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000116 ;
                    dc:identifier "SIO_000182" ;
                    terms:description "A last name (surname) is a name added to a given name and is part of a personal name and is often the family name."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "last name"@en .


###  http://semanticscience.org/resource/SIO_000183
resource:SIO_000183 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000116 ;
                    dc:identifier "SIO_000183" ;
                    terms:alternative "full name" ;
                    terms:description "A personal name is a name to identify an individual person and usually comprises of a first name and a last name."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "personal name"@en .


###  http://semanticscience.org/resource/SIO_000184
resource:SIO_000184 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000183 ;
                    dc:identifier "SIO_000184" ;
                    terms:description "A legal name is a name given at birth, or which appears on their birth certificate, marriage certificate, or change of name certificate."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "legal name"@en .


###  http://semanticscience.org/resource/SIO_000185
resource:SIO_000185 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000179 ;
                    dc:identifier "SIO_000185" ;
                    terms:description "A title is a textual entity that summarily describes some entity."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "title"@en .


###  http://semanticscience.org/resource/SIO_000186
resource:SIO_000186 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000653 ;
                    dc:identifier "SIO_000186" ;
                    terms:description "A document version is a version of a work in some sequence of derivative works."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "document version"@en .


###  http://semanticscience.org/resource/SIO_000188
resource:SIO_000188 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000111 ;
                    dc:identifier "SIO_000188" ;

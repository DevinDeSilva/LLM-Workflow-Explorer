###  http://semanticscience.org/resource/SIO_000924
resource:SIO_000924 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001194 ;
                    dc:identifier "SIO_000924" ;
                    terms:description "A television program is a audiovisual media that is produced and broadcast using a television."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;

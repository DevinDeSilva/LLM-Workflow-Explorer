                    terms:description "A line is curve that extends in a single dimension (e.g. straight line; exhibits no curvature), and is composed of at least two fully connected points."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "line"@en .


###  http://semanticscience.org/resource/SIO_000512
resource:SIO_000512 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000511 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000369 ;
                                      owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                      owl:onClass resource:SIO_000532
                                    ] ;
                    dc:identifier "SIO_000512" ;
                    terms:description "A line segment is a line and a part of a curve that is (inclusively) bounded by two terminal points."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "line segment"@en .


###  http://semanticscience.org/resource/SIO_000513
resource:SIO_000513 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000512 ;
                    dc:identifier "SIO_000513" ;
                    terms:description "A tick mark is a line segment that is spatially positioned perpendicular to the axis of a statistical graph and indicates the position of a specific numeric value (which may be indicated by an adjacent value label) on a value axis, or is one of a pair of tick marks that delineates the boundary of a categorical value (which may be indicated by an adjacent category label) on the categorical axis."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "tick mark"@en .


###  http://semanticscience.org/resource/SIO_000514
resource:SIO_000514 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000513 ;
                    dc:identifier "SIO_000514" ;
                    terms:description "A major tick mark is a tick mark that indicates the position of a specific numeric value and is adjacent to its value label on the value axis, or is one of a pair of tick marks that delineates the boundary of a categorical value indicated by an adjacent category label on the categorical axis."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "major tick mark"@en .


###  http://semanticscience.org/resource/SIO_000515
resource:SIO_000515 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000513 ;
                    dc:identifier "SIO_000515" ;
                    terms:description "A minor tick mark is a tick mark that indicates the position of a specific numeric value but has no adjacent value label, or is one of a pair of tick marks that delineates the boundary of a categorical value but has no adjacent category label on the categorical axis."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "minor tick mark"@en .


###  http://semanticscience.org/resource/SIO_000516
resource:SIO_000516 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000511 ;
                    dc:identifier "SIO_000516" ;
                    terms:description "A ray is a line which that is bounded by a startpoint and extends outwards infinitely along one dimension."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "ray"@en .


###  http://semanticscience.org/resource/SIO_000517
resource:SIO_000517 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000505 ;
                    dc:identifier "SIO_000517" ;
                    terms:description "A quadrilateral is a polygon with composed of four points and four line segments, in which each point is fully connected to two other points."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "quadrilateral"@en .


###  http://semanticscience.org/resource/SIO_000518
resource:SIO_000518 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000517 ;
                    dc:identifier "SIO_000518" ;
                    terms:description "A rectangle is a quadrilateral in which one pair of line segments are  parallel and the other pair are perpendicular to the first pair."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "rectangle"@en .


###  http://semanticscience.org/resource/SIO_000519
resource:SIO_000519 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000518 ;
                    dc:identifier "SIO_000519" ;
                    terms:description "A bar is a rectangle that is located in the plot of a statistical graph in which its length is proportional to the values that it represents."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "bar"@en .


###  http://semanticscience.org/resource/SIO_000520
resource:SIO_000520 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000505 ;
                    dc:identifier "SIO_000520" ;
                    terms:description "A triangle is a polygon composed of three points and three line segments, in which each point is fully connected to another point along through the line segment."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "triangle"@en .


###  http://semanticscience.org/resource/SIO_000521
resource:SIO_000521 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000512 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000369 ;
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass resource:SIO_000508
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000369 ;
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass resource:SIO_000509
                                    ] ;
                    dc:identifier "SIO_000521" ;
                    terms:description """A directed line segment is a line segment that is contained by an ordered pair 
of endpoints (a start point and an endpoint)."""@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "directed line segment"@en .


###  http://semanticscience.org/resource/SIO_000522
resource:SIO_000522 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000521 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000028 ;
                                      owl:someValuesFrom resource:SIO_000520
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000369 ;
                                      owl:maxQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                      owl:onClass resource:SIO_000520
                                    ] ;
                    dc:identifier "SIO_000522" ;
                    terms:description "An arrowed line is a directed line segment in which one or both endpoints is tangentially part of a triangle that bisects the line."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "arrowed line segment"@en .


###  http://semanticscience.org/resource/SIO_000523
resource:SIO_000523 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000522 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000369 ;
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass resource:SIO_000520
                                    ] ;
                    owl:disjointWith resource:SIO_000524 ;
                    dc:identifier "SIO_000523" ;
                    terms:description "A single arrowed line is directed line in which the endpoint is tangentially part of a triangle that bisects the line."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "single arrowed line segment"@en .


###  http://semanticscience.org/resource/SIO_000524
resource:SIO_000524 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000522 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000369 ;
                                      owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                      owl:onClass resource:SIO_000520
                                    ] ;
                    dc:identifier "SIO_000524" ;
                    terms:description "A double arrowed line is an arrowed line in which both terminal points are  tangentially part of different triangles that bisect the line."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "double arrowed line segment"@en .


###  http://semanticscience.org/resource/SIO_000525
resource:SIO_000525 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000534 ;
                    dc:identifier "SIO_000525" ;
                    terms:description "A horizontal line is a line that is positionally oriented with the horizon."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "horizontal line"@en .


###  http://semanticscience.org/resource/SIO_000526
resource:SIO_000526 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000534 ;
                    dc:identifier "SIO_000526" ;
                    terms:description "A vertical line is a line that is positionally oriented perpendicular to the horizon."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "vertical line"@en .


###  http://semanticscience.org/resource/SIO_000527
resource:SIO_000527 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000535 ;
                    dc:identifier "SIO_000527" ;
                    terms:description "A trend line is a line, line segment or ray that is part of a statistical graph which indicates a statistical or visual direction across categorical or value data."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "trend line"@en .


###  http://semanticscience.org/resource/SIO_000528
resource:SIO_000528 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000527 ;
                    dc:identifier "SIO_000528" ;
                    terms:description "An increasing line is a line segment in which the startpoint and endpoint are ordered along one dimension and the difference of values in a second dimension is positive."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "increasing line"@en .


###  http://semanticscience.org/resource/SIO_000529
resource:SIO_000529 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000527 ;
                    dc:identifier "SIO_000529" ;
                    terms:description "An decreasing line is a line segment in which the startpoint and endpoint are ordered along one dimension and the difference of values in a second dimension is negative."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "decreasing line"@en .


###  http://semanticscience.org/resource/SIO_000530
resource:SIO_000530 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000527 ;
                    dc:identifier "SIO_000530" ;
                    terms:description "An plateau line is a line segment in which the startpoint and endpoint are ordered along one dimension and the difference of values in a second dimension is zero."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "plateau line"@en .


###  http://semanticscience.org/resource/SIO_000531
resource:SIO_000531 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000535 ;
                    dc:identifier "SIO_000531" ;
                    terms:description "A drop line is a statistical graph line that vertically or horizontally connects a data series line with a value axis in a statistical graph."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "drop line"@en .


###  http://semanticscience.org/resource/SIO_000532
resource:SIO_000532 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000507 ;
                    dc:identifier "SIO_000532" ;
                    terms:description "A terminal point is a point that defines the finite extension of a line."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "terminal point"@en .


###  http://semanticscience.org/resource/SIO_000533
resource:SIO_000533 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000540 ;
                    dc:identifier "SIO_000533" ;
                    terms:description "A surface normal is a vector that is perpendicular to a flat surface."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "surface normal"@en .


###  http://semanticscience.org/resource/SIO_000534
resource:SIO_000534 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000511 ;
                    dc:identifier "SIO_000534" ;
                    terms:description "A positionally oriented line is a line that is positioned against some axis of reference."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "positionally oriented line"@en .


###  http://semanticscience.org/resource/SIO_000535
resource:SIO_000535 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000511 ;
                    dc:identifier "SIO_000535" ;
                    terms:description "A statistical graph line is a line used in a statistical graph to communicate some trend or feature of the embedded data."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "statistical graph line"@en .


###  http://semanticscience.org/resource/SIO_000536
resource:SIO_000536 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000395 ;
                    dc:identifier "SIO_000536" ;
                    terms:description "to regulate the rate of formation is to modify the rate at which an object is formed."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "to regulate the rate of formation"@en .


###  http://semanticscience.org/resource/SIO_000537
resource:SIO_000537 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000055 ;
                    dc:identifier "SIO_000537" ;
                    terms:description "curvature is a quality of a bearer that relates to the presence of curves, bends, or angles."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "curvature"@en .


###  http://semanticscience.org/resource/SIO_000538
resource:SIO_000538 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000537 ;
                    dc:identifier "SIO_000538" ;
                    terms:description "straight is a quality of a bearer that is free of curves, bends, or angles."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "straight"@en ;
                    rdfs:seeAlso "PATO:0002180 [for material entities]" .


###  http://semanticscience.org/resource/SIO_000539
resource:SIO_000539 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000511 ;
                    dc:identifier "SIO_000539" ;
                    terms:description "An infinite line is a line that extends outwards in both directions of a single dimensional and is not bounded by terminal points."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "infinite line"@en .


###  http://semanticscience.org/resource/SIO_000540
resource:SIO_000540 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000516 ;
                    dc:identifier "SIO_000540" ;
                    terms:description "A vector line is a line which that is bounded by a startpoint and extends outwards along one dimension."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "vector line"@en .


###  http://semanticscience.org/resource/SIO_000541
resource:SIO_000541 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000540 ;
                    dc:identifier "SIO_000541" ;
                    terms:description "A vertext normal is the normalized average of the surface normals of the faces that contain that vertex."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "vertex normal"@en .


###  http://semanticscience.org/resource/SIO_000542
resource:SIO_000542 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000494 ;
                    dc:identifier "SIO_000542" ;
                    terms:description "to serve as is the capability to act in a manner corresponding to some role."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "to serve as"@en .


###  http://semanticscience.org/resource/SIO_000543
resource:SIO_000543 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000542 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000646 ;
                                      owl:someValuesFrom resource:SIO_010415
                                    ] ;
                    dc:identifier "SIO_000543" ;
                    terms:description "to serve as host is the capability to act in a manner that provides hospitality, serves to harbour an organism in or on itself."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "to serve as a host"@en .


###  http://semanticscience.org/resource/SIO_000544
resource:SIO_000544 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000372 ;
                    dc:identifier "SIO_000544" ;
                    terms:description "to infect is the capability to administer a disease-causing organism into some object."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "to infect"@en .


###  http://semanticscience.org/resource/SIO_000545
resource:SIO_000545 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000506 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000369 ;
                                      owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                      owl:onClass resource:SIO_000512
                                    ] ;
                    dc:identifier "SIO_000545" ;
                    terms:alternative "polygonal chain, polygonal curve, polygonal path, piecewise linear curve" ;
                    terms:description "A polyline is a connected sequence of line segments."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "polyline"@en .


###  http://semanticscience.org/resource/SIO_000546
resource:SIO_000546 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000506 ,
                                    resource:SIO_000616 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000059 ;
                                      owl:allValuesFrom resource:SIO_000507
                                    ] ;
                    dc:identifier "SIO_000546" ;
                    terms:description "A collection of points is a geometric entity that contains a non-zero set of geometric points. "@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "collection of points"@en .


###  http://semanticscience.org/resource/SIO_000547
resource:SIO_000547 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000376 ;
                    dc:identifier "SIO_000547" ;
                    terms:description "to cause disease is the capability to materially change a biological object in that it functions abnormally."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "to cause disease"@en .


###  http://semanticscience.org/resource/SIO_000549
resource:SIO_000549 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000551 ;
                    owl:disjointWith resource:SIO_000550 ;
                    dc:identifier "SIO_000549" ;
                    terms:alternative "to activate" ;
                    terms:description "to reduce the activation energy is to require a smaller amount of energy in order to form or break a chemical bond."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "to reduce the activation energy"@en .


###  http://semanticscience.org/resource/SIO_000550
resource:SIO_000550 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000551 ;
                    dc:identifier "SIO_000550" ;
                    terms:alternative "to inhibit" ;
                    terms:description "to increase the activation energy is to require a larger amount of energy in order to form or break a chemical bond."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "to increase the activation energy"@en .


###  http://semanticscience.org/resource/SIO_000551
resource:SIO_000551 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000385 ;
                    dc:identifier "SIO_000551" ;
                    terms:description "to change the activation energy is to change the amount of energy required to form or break a chemical bond."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "to change the activation energy"@en .


###  http://semanticscience.org/resource/SIO_000554
resource:SIO_000554 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000307 ;
                    owl:disjointWith resource:SIO_000555 ;
                    dc:identifier "SIO_000554" ;
                    terms:description "A quality that has a value that is normal or average."@en ;
                    resource:equivalentTo "PATO:0000461" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "normal"@en .


###  http://semanticscience.org/resource/SIO_000555
resource:SIO_000555 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000307 ;
                    dc:identifier "SIO_000555" ;
                    terms:description "A quality that has a value that is outside normal or average."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "abnormal"@en .


###  http://semanticscience.org/resource/SIO_000556
resource:SIO_000556 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010071 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000068 ;
                                      owl:someValuesFrom resource:SIO_010011
                                    ] ;
                    dc:identifier "SIO_000556" ;
                    terms:description "A lipid residue is a part of an organic molecule that was derived from a lipid molecule."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "lipid residue"@en .


###  http://semanticscience.org/resource/SIO_000559
resource:SIO_000559 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000588 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000139 ;
                                      owl:someValuesFrom resource:SIO_010343
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000312 ;
                                      owl:someValuesFrom resource:SIO_010004
                                    ] ;
                    dc:identifier "SIO_000559" ;
                    terms:description "chemical synthesis is synthesis of a chemical entity from physical precursors through one or more chemical interactions or reactions."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "chemical synthesis"@en .


###  http://semanticscience.org/resource/SIO_000561
resource:SIO_000561 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001011 ;
                    dc:identifier "SIO_000561" ;
                    terms:description "A molecular orbital (or MO) is a mathematical function describing the wave-like behavior of an electron in a molecule."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "molecular orbital"@en .


###  http://semanticscience.org/resource/SIO_000562
resource:SIO_000562 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000576 ;
                    owl:disjointWith resource:SIO_010284 ;
                    dc:identifier "SIO_000562" ;
                    terms:description "passive transport is the movement of a substance across a membrane and does not require chemical energy."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "passive transport"@en .


###  http://semanticscience.org/resource/SIO_000564
resource:SIO_000564 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000573 ;
                    dc:identifier "SIO_000564" ;
                    terms:description "diffusion is motion of particles at temperatures above absolute zero."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "diffusion"@en .


###  http://semanticscience.org/resource/SIO_000565
resource:SIO_000565 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000566 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000338 ;
                                      owl:someValuesFrom resource:SIO_000564
                                    ] ;
                    dc:identifier "SIO_000565" ;
                    terms:description "A diffusion equation describes density fluctuations in a material undergoing diffusion."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "diffusion equation"@en .


###  http://semanticscience.org/resource/SIO_000566
resource:SIO_000566 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000368 ;
                    dc:identifier "SIO_000566" ;
                    terms:description "A movement equation describes the displacement of an object in space over time."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "movement equation"@en .


###  http://semanticscience.org/resource/SIO_000567

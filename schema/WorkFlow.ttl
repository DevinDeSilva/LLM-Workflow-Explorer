###  http://semanticscience.org/resource/SIO_000071
resource:SIO_000071 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000056 ;
                    dc:identifier "SIO_000071" ;
                    terms:description "A coordinate is a measurement of position in n-dimensional space."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "coordinate"@en .


###  http://semanticscience.org/resource/SIO_000072
resource:SIO_000072 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000071 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000093 ;
                                      owl:someValuesFrom resource:SIO_000321
                                    ] ;
                    owl:disjointWith resource:SIO_000073 ;

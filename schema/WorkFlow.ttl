                    rdfs:subClassOf resource:SIO_000078 ;
                    dc:identifier "SIO_000108" ;
                    terms:description "A character is a language symbol used to construct words."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "character"@en .



                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "professor"@en .


###  http://semanticscience.org/resource/SIO_000405
resource:SIO_000405 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000406 ;
                    dc:identifier "SIO_000405" ;
                    terms:description "A student is an individual who is attends an educational institution."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "student"@en .


###  http://semanticscience.org/resource/SIO_000406
resource:SIO_000406 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000498 ;
                    dc:identifier "SIO_000406" ;
                    terms:description "An academic is an individual that participates in education and scholarship."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "academic"@en .


###  http://semanticscience.org/resource/SIO_000407
resource:SIO_000407 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000536 ;
                    dc:identifier "SIO_000407" ;
                    terms:description "to increase the rate of formation is to regulate the rate of formation in a manner that increases this rate relative to a reference process."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "to increase the rate of formation"@en .


###  http://semanticscience.org/resource/SIO_000408
resource:SIO_000408 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000494 ;
                    dc:identifier "SIO_000408" ;
                    terms:description "to investigate is the capability to uncover facts."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "to investigate"@en .


###  http://semanticscience.org/resource/SIO_000409
resource:SIO_000409 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000014 ;
                    dc:identifier "SIO_000409" ;
                    terms:description "A mutual disposition is a disposition that simulataneously invokes another disposition when realized."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "mutual disposition"@en .


###  http://semanticscience.org/resource/SIO_000410
resource:SIO_000410 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000828 ;
                    dc:identifier "SIO_000410" ;
                    terms:description "anger is disgust directed toward an equal status individual."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "anger"@en .


###  http://semanticscience.org/resource/SIO_000411
resource:SIO_000411 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000828 ;
                    dc:identifier "SIO_000411" ;
                    terms:description "Hate is a deep and emotional extreme dislike, directed against a certain object or class of objects. "@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "hate"@en .


###  http://semanticscience.org/resource/SIO_000412
resource:SIO_000412 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000831 ;
                    dc:identifier "SIO_000412" ;
                    terms:description "love is an emotion of a strong affection and personal attachment."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "love"@en .


###  http://semanticscience.org/resource/SIO_000413
resource:SIO_000413 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000414 ;
                    dc:identifier "SIO_000413" ;
                    terms:description "A geolegal region is a geographic region which has causal powers confered by a legal entity."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "geolegal region"@en ;
                    skos:example "The 50 kph zones in Ottawa; the geographic region occupied by France."@en .


###  http://semanticscience.org/resource/SIO_000414
resource:SIO_000414 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000370 ;
                    dc:identifier "SIO_000414" ;
                    terms:description "A geographic region is a spatial region whose boundaries are typically defined against some material frame of reference (like the earth)."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "geographic region"@en ;
                    skos:example "The spatial region occupied by the province of ontario; the spatial region occupied by a lake."@en .


###  http://semanticscience.org/resource/SIO_000415
resource:SIO_000415 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000413 ;
                    dc:identifier "SIO_000415" ;
                    terms:description "a geopolitical region is a geographic region recognized by social or legal convention."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "geopolitical region"@en ;
                    skos:example "The geographic region bounded by Canada; the spatial region occupied by the US embassy in Ottawa."@en .


###  http://semanticscience.org/resource/SIO_000417
resource:SIO_000417 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000391 ;
                    dc:identifier "SIO_000417" ;
                    terms:description "A time internval is a contiguous temporal region having some duration."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "time interval"@en .


###  http://semanticscience.org/resource/SIO_000418
resource:SIO_000418 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000391 ;
                    dc:identifier "SIO_000418" ;
                    terms:description "A time instant is a temporal region which occurs instantaneously, e.g. having no duration."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "time instant"@en ;
                    skos:example "at this moment; the moment at which a finger is detached in an industrial accident; the moment at which a child is born; the moment of death"@en .


###  http://semanticscience.org/resource/SIO_000419
resource:SIO_000419 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000080 ;
                    dc:identifier "SIO_000419" ;
                    terms:description "A table is a figure that consists of an ordered arrangement of columns and rows."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "table"@en .


###  http://semanticscience.org/resource/SIO_000423
resource:SIO_000423 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000083 ;
                    dc:identifier "SIO_000423" ;
                    terms:alternative "scatter chart"@en ,
                                      "scatter diagram"@en ,
                                      "scatter graph"@en ;
                    terms:description "A scatterplot is a statistical graph which uses Cartesian coordinates to display values for two variables for a set of data. The data is displayed as a collection of points, each having the value of one variable determining the position on the horizontal axis and the value of the other variable determining the position on the vertical axis."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "scatterplot"@en .


###  http://semanticscience.org/resource/SIO_000428
resource:SIO_000428 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000417 ;
                    dc:identifier "SIO_000428" ;
                    terms:description "A year is a period of time taken by a planet to make one revolution around the sun."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "year"@en .


###  http://semanticscience.org/resource/SIO_000429
resource:SIO_000429 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000417 ;
                    dc:identifier "SIO_000429" ;
                    terms:description "A month is a period of time that divides the year."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "month"@en .


###  http://semanticscience.org/resource/SIO_000430
resource:SIO_000430 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000417 ;
                    dc:identifier "SIO_000430" ;
                    terms:description "A day is a period of 24 hours."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "day"@en .


###  http://semanticscience.org/resource/SIO_000431
resource:SIO_000431 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000417 ;
                    dc:identifier "SIO_000431" ;
                    terms:description "A century is a period of one hundred years."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "century"@en .


###  http://semanticscience.org/resource/SIO_000432
resource:SIO_000432 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000417 ;
                    dc:identifier "SIO_000432" ;
                    terms:description "A millenium is a period of 1000 years"@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "millennium"@en .


###  http://semanticscience.org/resource/SIO_000433
resource:SIO_000433 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000417 ;
                    dc:identifier "SIO_000433" ;
                    terms:description "An hour is a period of 60 minutes."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "hour"@en .


###  http://semanticscience.org/resource/SIO_000434
resource:SIO_000434 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000417 ;
                    dc:identifier "SIO_000434" ;
                    terms:description "A minute is a period of 60 seconds."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "minute"@en .


###  http://semanticscience.org/resource/SIO_000435
resource:SIO_000435 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000417 ;
                    dc:identifier "SIO_000435" ;
                    terms:description "A second (symbol: s) is the base unit of time in the International System of Units (SI) and is the second division of the hour by sixty, the first division by 60 being the minute."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "second"@en .


###  http://semanticscience.org/resource/SIO_000436
resource:SIO_000436 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000005 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000218 ;
                                      owl:someValuesFrom resource:SIO_000015
                                    ] ;
                    dc:identifier "SIO_000436" ;
                    terms:description "An informational quality is a quality that pertains to information."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "informational quality"@en .


###  http://semanticscience.org/resource/SIO_000437
resource:SIO_000437 rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( resource:SIO_000507
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty resource:SIO_000369 ;
                                                                 owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                     owl:unionOf ( resource:SIO_000400
                                                                                                   resource:SIO_000401
                                                                                                 )
                                                                                   ]
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty resource:SIO_000369 ;
                                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                 owl:onClass resource:SIO_000400
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty resource:SIO_000369 ;
                                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                 owl:onClass resource:SIO_000401
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf resource:SIO_000507 ;
                    dc:identifier "SIO_000437" ;
                    terms:description "A 2D cartesian point is a point whose position is specified along two  dimensions using Cartesian coordinates."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "2D cartesian point"@en .


###  http://semanticscience.org/resource/SIO_000438
resource:SIO_000438 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000056 ;
                    dc:identifier "SIO_000438" ;
                    terms:description "Altitude is a distance above sea level."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "altitude"@en .


###  http://semanticscience.org/resource/SIO_000439
resource:SIO_000439 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_000056 ;
                    dc:identifier "SIO_000439" ;
                    terms:description "The center of mass (aka barycenter) is the weighted average location of all the mass in a body or group of bodies."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "center of mass"@en .


###  http://semanticscience.org/resource/SIO_000440
resource:SIO_000440 rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( resource:SIO_000507
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty resource:SIO_000369 ;
                                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                 owl:onClass resource:SIO_000400
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty resource:SIO_000369 ;

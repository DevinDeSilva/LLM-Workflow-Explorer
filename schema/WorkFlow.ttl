                    terms:description "An inorganic reaction is a chemical reaction that involves the transformation of inorganic molecules."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "inorganic reaction"@en .


###  http://semanticscience.org/resource/SIO_010511
resource:SIO_010511 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010510 ;
                    dc:identifier "SIO_010511" ;
                    terms:description "A decomposition reaction is an inorganic reaction in which molecule is fragmented into submolecules or atoms."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "decomposition reaction"@en .


###  http://semanticscience.org/resource/SIO_010512
resource:SIO_010512 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010510 ;
                    dc:identifier "SIO_010512" ;
                    terms:description "A displacement reaction is an inorganic reaction in which a elementary substance displaces and sets free a constituent atom from a molecule."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "displacement reaction"@en .


###  http://semanticscience.org/resource/SIO_010513
resource:SIO_010513 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010512 ;
                    dc:identifier "SIO_010513" ;
                    terms:description "A double displacement reaction is a displacement reaction in which two molecules swap ions, effectively displacing each other to form two new molecules."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "double displacement reaction"@en .


###  http://semanticscience.org/resource/SIO_010514
resource:SIO_010514 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010512 ;
                    dc:identifier "SIO_010514" ;
                    terms:description "A single displacement reaction where one atom is transferred out of one molecule and into another."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "single displacement reaction"@en .


###  http://semanticscience.org/resource/SIO_010515
resource:SIO_010515 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010510 ;
                    dc:identifier "SIO_010515" ;
                    terms:description "A synthesis reaction is an inorganic reaction in which two or more molecules are chemically bonded together to produce a single product."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "synthesis reaction"@en .


###  http://semanticscience.org/resource/SIO_010516
resource:SIO_010516 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010345 ;
                    dc:identifier "SIO_010516" ;
                    terms:description "An organic reaction is a chemical reaction involving at least one organic molecule."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "organic reaction"@en .


###  http://semanticscience.org/resource/SIO_010517
resource:SIO_010517 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010345 ;
                    dc:identifier "SIO_010517" ;
                    terms:description "An isomerization reaction is a chemical reaction in which a molecule is converted into its isomer."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "isomerization reaction"@en .


###  http://semanticscience.org/resource/SIO_010518
resource:SIO_010518 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010516 ;
                    dc:identifier "SIO_010518" ;
                    terms:description """An addition reaction is an organic reaction where two or more molecules combine to form a larger one. Addition reactions are limited to chemical compounds that have multiply-bonded atoms:
    * Molecules with carbon-carbon double bonds or triple bonds
    * Molecules with carbon - hetero double bonds like C=O or C=N"""@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "addition reaction"@en .


###  http://semanticscience.org/resource/SIO_010519
resource:SIO_010519 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010518 ;
                    dc:identifier "SIO_010519" ;
                    terms:description "A polar addition reaction is an addition reaction involving polar residues."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "polar addition reaction"@en .


###  http://semanticscience.org/resource/SIO_010520
resource:SIO_010520 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010518 ;
                    dc:identifier "SIO_010520" ;
                    terms:description "A non-polar addition reaction is an addition reaction involving non-polar residues."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "non-polar addition reaction"@en .


###  http://semanticscience.org/resource/SIO_010521
resource:SIO_010521 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010520 ;
                    dc:identifier "SIO_010521" ;
                    terms:description "A free radical addition is a non-polar addition reaction involving free radicals."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "free radical addition"@en .


###  http://semanticscience.org/resource/SIO_010522
resource:SIO_010522 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010519 ;
                    dc:identifier "SIO_010522" ;
                    terms:description "A nucleophilic addition reaction is an addition reaction where a pi bond is removed by the creation of two new covalent bonds by the addition from a nucleophile."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "nucleophilic addition reaction"@en .


###  http://semanticscience.org/resource/SIO_010523
resource:SIO_010523 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010519 ;
                    dc:identifier "SIO_010523" ;
                    terms:description "An electrophilic addition reaction is a polar addition reaction where a pi bond is removed by the creation of two new covalent bonds."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "electrophilic addition reaction"@en .


###  http://semanticscience.org/resource/SIO_010525
resource:SIO_010525 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_010526 ;
                    dc:identifier "SIO_010525" ;
                    terms:description "A biochemical pathway specifies a series of biochemical modifications and transformations towards achieving some biological outcome."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "biochemical pathway"@en .


###  http://semanticscience.org/resource/SIO_010526
resource:SIO_010526 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001107 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty resource:SIO_000338 ;
                                      owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                           owl:onProperty resource:SIO_000053 ;
                                                           owl:someValuesFrom resource:SIO_010345
                                                         ]

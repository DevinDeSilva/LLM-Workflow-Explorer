                    rdfs:subClassOf resource:SIO_000578 ;
                    owl:disjointWith resource:SIO_000580 ;
                    dc:identifier "SIO_000579" ;
                    terms:description "symport enabled secondary active transport is a secondary active transfort in which both ion and molecule are transported in the same direction simultaneously."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "symport enabled secondary active transport"@en .


###  http://semanticscience.org/resource/SIO_000580

                    rdfs:subClassOf resource:SIO_001212 ;
                    dc:identifier "SIO_001214" ;
                    terms:description "moderate is a qualitative intensity value that is more intense than mild, but less intense than strong."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "moderate"@en .


###  http://semanticscience.org/resource/SIO_001215
resource:SIO_001215 rdf:type owl:Class ;
                    rdfs:subClassOf resource:SIO_001212 ;
                    dc:identifier "SIO_001215" ;
                    terms:description "severe is a qualitative intensity value that is more intense than strong, but less intense than fatal."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "severe"@en .



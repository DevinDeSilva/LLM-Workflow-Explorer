schema:comment rdf:type owl:AnnotationProperty ;
               dc:identifier "comment" .


###  http://semanticscience.org/resource/broaderThan
resource:broaderThan rdf:type owl:AnnotationProperty ;
                     dc:identifier "broaderThan" ;
                     rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> .


###  http://semanticscience.org/resource/equivalentTo
resource:equivalentTo rdf:type owl:AnnotationProperty ;
                      dc:identifier "equivalentTo" ;
                      rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> .



                    rdfs:subClassOf resource:SIO_000006 ;
                    dc:identifier "SIO_000570" ;
                    terms:description "movement is the process in which an object is spatially displaced."@en ;
                    resource:subset "core" ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "movement"@en .


###  http://semanticscience.org/resource/SIO_000571

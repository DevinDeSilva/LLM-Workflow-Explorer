###  https://purl.org/heals/eo#ExplanationGoal
<https://purl.org/heals/eo#ExplanationGoal> rdf:type owl:Class ;
                                            rdfs:subClassOf resource:SIO_000337 ;
                                            dc:description "the impact that an explanation has on a user or the purpose it was designed to achieve" ;
                                            rdfs:label "Explanation Goal" ;
                                            skos:example "educational" .


###  https://purl.org/heals/eo#ExplanationMethod
<https://purl.org/heals/eo#ExplanationMethod> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://purl.org/heals/eo#ArtificialIntelligenceMethod> ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty resource:SIO_000229 ;
                                                                owl:someValuesFrom <https://purl.org/heals/eo#ModelExplanationOutputs>
                                                              ] ;
                                              dc:description "mechanisms that can provide explanations that are understandable to humans (interpretability) and accurately describe model behaviour in the entire feature space (fidelity)" ;
                                              terms:source "Zhou, J., Gandomi, A. H., Chen, F., & Holzinger, A. (2021). Evaluating the quality of machine learning explanations: A survey on methods and metrics. Electronics, 10(5), 593." ;

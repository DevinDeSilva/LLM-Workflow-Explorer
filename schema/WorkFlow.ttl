                    rdfs:subClassOf resource:SIO_001263 ;
                    dc:identifier "SIO_001265" ;
                    terms:description "homozygous is the quality of a biological organism in which there are two different alleles at a given locus." ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "heterozygous"@en .


###  http://semanticscience.org/resource/SIO_001266

                    rdfs:subClassOf resource:SIO_001263 ;
                    dc:identifier "SIO_001266" ;
                    terms:description "hemizygous is the quality of a biological organism in which, based on the ploidy of the organism, there is half the number of alleles than normal at a given locus." ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "hemizygous"@en .



                                      owl:onProperty resource:SIO_010079 ;
                                      owl:someValuesFrom resource:SIO_000985
                                    ] ;
                    dc:identifier "SIO_001445" ;
                    terms:description "a protein isoform is a protein that is a structural variant (different sequence of amino acids and/or post-translational modifications) of another protein, but encoded by the same gene."@en ;

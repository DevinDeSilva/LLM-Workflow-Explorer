                    rdfs:subClassOf resource:SIO_000238 ;
                    dc:identifier "SIO_000281" ;
                    terms:description "NOT is a logical operator in that has the value true if its operand is false."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;

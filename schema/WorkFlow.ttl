                    rdfs:subClassOf resource:SIO_001212 ;
                    dc:identifier "SIO_001216" ;
                    terms:description "fatal is a qualitative intensity value that is more intense than severe, leading to the death/non-functioning of a system."@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
                    rdfs:label "fatal"@en .



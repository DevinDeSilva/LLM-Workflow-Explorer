                    rdfs:subClassOf resource:SIO_000747 ;
                    dc:identifier "SIO_000994" ;
                    terms:alternative "study" ;
                    terms:description "An experiment is an investigation that has the goal of verifying, falsifying, or establishing the validity of a hypothesis. "@en ;
                    rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
